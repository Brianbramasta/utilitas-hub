---
// BuyVsRentUniversal.astro
// Anda bisa langsung memasukkan komponen ini ke dalam layout utama Astro Anda.
---

<div class="max-w-6xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden my-4">
    <!-- Header -->
    <div class="bg-emerald-600 p-6 text-white text-center">
        <h1 class="text-2xl md:text-3xl font-bold break-words">Universal Buy vs Rent Calculator</h1>
        <p class="text-emerald-100 mt-2 text-sm md:text-base break-words">Bandingkan keputusan finansial beli vs sewa untuk Rumah, Kendaraan, Gadget, atau Alat Bisnis.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 p-6">
        <!-- Form Input -->
        <div class="lg:col-span-1 space-y-5 bg-slate-50 p-4 rounded-xl border border-slate-200">
            <h2 class="text-lg font-bold border-b border-slate-200 pb-2 text-slate-700">Karakteristik Aset</h2>
            
            <!-- Jenis Aset Dropdown -->
            <div>
                <label class="block text-xs font-medium text-slate-500 mb-1">Jenis Aset</label>
                <select id="assetType" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="depreciating">Kendaraan / Elektronik / Alat (Menyusut)</option>
                    <option value="appreciating">Properti / Tanah (Nilai Naik)</option>
                </select>
            </div>

            <hr class="border-slate-200">

            <!-- Skenario Beli -->
            <div class="space-y-4">
                <h3 class="font-semibold text-blue-600 text-sm tracking-wider uppercase">Opsi Beli / Kredit</h3>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Harga Tunai Aset (Rp)</label>
                    <input type="text" id="assetPrice" value="300.000.000" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 rupiah-input">
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Uang Muka / DP (Rp)</label>
                    <input type="text" id="downPayment" value="60.000.000" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 rupiah-input">
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-1">Bunga Pinjaman (%/Thn)</label>
                        <input type="number" id="loanInterest" value="6" step="0.1" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-1">Tenor (Tahun)</label>
                        <input type="number" id="loanTerm" value="5" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    </div>
                </div>
                <div>
                    <label id="growthLabel" class="block text-xs font-medium text-slate-500 mb-1">Penyusutan Nilai Aset (% per Tahun)</label>
                    <input type="number" id="assetGrowthRate" value="15" step="0.1" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                </div>
            </div>

            <hr class="border-slate-200">

            <!-- Skenario Sewa -->
            <div class="space-y-4">
                <h3 class="font-semibold text-emerald-600 text-sm tracking-wider uppercase">Opsi Sewa / Leasing</h3>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Biaya Sewa (Rp / Bulan)</label>
                    <input type="text" id="monthlyRent" value="6.000.000" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 rupiah-input">
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Return Investasi Sisa Dana (%/Thn)</label>
                    <input type="number" id="investmentReturn" value="8" step="0.1" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                </div>
            </div>

            <button id="btnCalculate" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold p-3 rounded-lg text-sm transition shadow-md cursor-pointer">Hitung Perbandingan</button>
            
            <div class="mb-4">
                <button id="btn-toggle-json" class="border border-slate-300 hover:border-slate-400 text-slate-600 hover:text-slate-800 text-xs py-2 px-4 rounded-lg cursor-pointer w-full transition font-medium">
                    📝 Import/Export JSON
                </button>
            </div>

            <div id="json-section" class="mb-4 hidden">
                <div class="bg-slate-100 p-4 rounded-lg border border-slate-300">
                    <label class="block text-xs font-semibold text-slate-600 mb-2">Import Data dari JSON:</label>
                    <textarea id="json-input" class="w-full h-48 bg-white border border-slate-300 rounded-lg p-3 text-xs text-slate-700 font-mono outline-none focus:border-emerald-500 resize-y" placeholder='{
  "assetType": "depreciating",
  "assetPrice": "300.000.000",
  "downPayment": "60.000.000",
  "loanInterest": 6,
  "loanTerm": 5,
  "assetGrowthRate": 15,
  "monthlyRent": "6.000.000",
  "investmentReturn": 8
}'></textarea>
                    <div class="flex gap-2 mt-3">
                        <button id="btn-import-json" class="bg-blue-600 hover:bg-blue-500 text-white text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition flex-1">Import JSON</button>
                        <button id="btn-export-json" class="bg-slate-600 hover:bg-slate-500 text-white text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition flex-1">Export JSON</button>
                        <button id="btn-clear-json" class="bg-red-600 hover:bg-red-500 text-white text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition">Clear</button>
                    </div>
                    <div class="flex gap-2 mt-2">
                        <button id="btn-reset-data" class="bg-orange-600 hover:bg-orange-500 text-white text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition w-full">🔄 Reset ke Default</button>
                    </div>
                    <p id="json-error" class="text-red-600 text-xs mt-2 hidden"></p>
                </div>
            </div>
        </div>

        <!-- Hasil & Grafik -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Ringkasan Singkat / Hasil Keputusan -->
            <div id="verdictBox" class="p-4 rounded-xl border flex flex-col justify-center items-center text-center">
                <h2 class="text-xl font-bold" id="verdictTitle">Menghitung...</h2>
                <p class="text-sm mt-1 text-slate-600" id="verdictDesc"></p>
            </div>

            <!-- Kartu Posisi Finansial Akhir -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Hasil Opsi Beli -->
                <div class="border border-blue-100 bg-blue-50/40 p-4 rounded-xl">
                    <span class="text-xs font-semibold text-blue-600 uppercase tracking-wider">Nilai Finansial Akhir (Beli)</span>
                    <div class="text-2xl font-bold mt-1 text-blue-900" id="buyTotalValue">Rp 0</div>
                    <div class="text-xs text-slate-500 mt-2 space-y-1">
                        <p>Cicilan Bulanan: <span class="font-medium text-slate-700" id="lblMortgage">Rp 0</span></p>
                        <p>Sisa Nilai Jual Aset: <span class="font-medium text-slate-700" id="lblFinalAssetVal">Rp 0</span></p>
                    </div>
                </div>

                <!-- Hasil Opsi Sewa -->
                <div class="border border-emerald-100 bg-emerald-50/40 p-4 rounded-xl">
                    <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wider">Nilai Finansial Akhir (Sewa)</span>
                    <div class="text-2xl font-bold mt-1 text-emerald-900" id="rentTotalValue">Rp 0</div>
                    <div class="text-xs text-slate-500 mt-2 space-y-1">
                        <p>Total Biaya Sewa: <span class="font-medium text-slate-700" id="lblTotalRentPaid">Rp 0</span></p>
                        <p>Sisa Uang di Investasi: <span class="font-medium text-slate-700" id="lblFinalInvest">Rp 0</span></p>
                    </div>
                </div>
            </div>

            <!-- Grafik Proyeksi -->
            <div class="bg-white p-4 border border-slate-200 rounded-xl">
                <h3 class="text-sm font-semibold text-slate-600 mb-4">Proyeksi Finansial Kumulatif per Tahun</h3>
                <div class="relative w-full h-64 md:h-80">
                    <canvas id="comparisonChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Menggunakan client-side script tag bawaan Astro -->
<script>
    import Chart from 'chart.js/auto';

    let chartInstance: Chart | null = null;

    // Fungsi pemformatan visual angka ke ribuan berkoma/titik saat user mengetik
    function formatNumberWithDots(value: string) {
        // Ambil hanya karakter angka
        let num = value.replace(/\D/g, "");
        if (num === "") return "";
        return new Intl.NumberFormat('id-ID').format(parseFloat(num));
    }

    // Fungsi konversi string berpemisah titik ke tipe data float murni untuk kalkulasi
    function parseRupiahInput(id: string) {
        const inputElement = document.getElementById(id) as HTMLInputElement;
        const rawValue = inputElement ? inputElement.value : "0";
        // Hilangkan titik agar menjadi deretan angka murni kembali
        const cleanValue = rawValue.replace(/\./g, "");
        return parseFloat(cleanValue) || 0;
    }

    function formatRupiahOutput(number: number): string {
        if (number < 0) return '- ' + formatRupiahOutput(Math.abs(number));
        return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(number);
    }

    function presetAssetType() {
        const assetTypeEl = document.getElementById('assetType') as HTMLSelectElement;
        const growthLabel = document.getElementById('growthLabel');
        const assetGrowthInput = document.getElementById('assetGrowthRate') as HTMLInputElement;

        if (!assetTypeEl || !growthLabel || !assetGrowthInput) return;

        if (assetTypeEl.value === 'depreciating') {
            growthLabel.innerText = "Penyusutan Nilai Aset (% per Tahun)";
            assetGrowthInput.value = "15";
        } else {
            growthLabel.innerText = "Kenaikan Nilai Aset (% per Tahun)";
            assetGrowthInput.value = "4";
        }
    }

    function calculate() {
        const assetTypeEl = document.getElementById('assetType') as HTMLSelectElement;
        const loanInterestInput = document.getElementById('loanInterest') as HTMLInputElement;
        const loanTermInput = document.getElementById('loanTerm') as HTMLInputElement;
        const assetGrowthRateInput = document.getElementById('assetGrowthRate') as HTMLInputElement;
        const investmentReturnInput = document.getElementById('investmentReturn') as HTMLInputElement;

        const assetType = assetTypeEl ? assetTypeEl.value : 'depreciating';
        const assetPrice = parseRupiahInput('assetPrice');
        const downPayment = parseRupiahInput('downPayment');
        const loanInterest = (parseFloat(loanInterestInput?.value) || 0) / 100;
        const loanTerm = parseInt(loanTermInput?.value) || 1;
        let assetGrowthRate = (parseFloat(assetGrowthRateInput?.value) || 0) / 100;
        const monthlyRent = parseRupiahInput('monthlyRent');
        const investmentReturn = (parseFloat(investmentReturnInput?.value) || 0) / 100;

        if (assetType === 'depreciating') {
            assetGrowthRate = -Math.abs(assetGrowthRate);
        }

        const loanPrincipal = assetPrice - downPayment;
        const monthlyInterest = loanInterest / 12;
        const totalMonths = loanTerm * 12;
        
        let monthlyPayment = 0;
        if (monthlyInterest > 0 && loanPrincipal > 0) {
            monthlyPayment = loanPrincipal * (monthlyInterest * Math.pow(1 + monthlyInterest, totalMonths)) / (Math.pow(1 + monthlyInterest, totalMonths) - 1);
        } else if (loanPrincipal > 0) {
            monthlyPayment = loanPrincipal / totalMonths;
        }

        let labels = [];
        let buyTimeline = [];
        let rentTimeline = [];

        let currentAssetValue = assetPrice;
        let remainingLoan = loanPrincipal;
        let rentInvestment = downPayment; 
        let totalRentPaid = 0;

        for (let year = 1; year <= loanTerm; year++) {
            labels.push(`Tahun ${year}`);

            for (let month = 1; month <= 12; month++) {
                currentAssetValue *= (1 + assetGrowthRate / 12);
                
                if (remainingLoan > 0) {
                    let interestCost = remainingLoan * monthlyInterest;
                    let principalPaid = monthlyPayment - interestCost;
                    remainingLoan -= principalPaid;
                    if (remainingLoan < 0) remainingLoan = 0;
                }

                rentInvestment *= (1 + investmentReturn / 12);
                totalRentPaid += monthlyRent;

                let buyCashflow = remainingLoan > 0 ? monthlyPayment : 0;
                let cashflowDifference = buyCashflow - monthlyRent;
                rentInvestment += cashflowDifference; 
            }

            let netWorthBuy = currentAssetValue - remainingLoan;
            let netWorthRent = rentInvestment;

            buyTimeline.push(Math.round(netWorthBuy));
            rentTimeline.push(Math.round(netWorthRent));
        }

        const finalBuy = buyTimeline[loanTerm - 1];
        const finalRent = rentTimeline[loanTerm - 1];

        document.getElementById('buyTotalValue')!.innerText = formatRupiahOutput(finalBuy);
        document.getElementById('rentTotalValue')!.innerText = formatRupiahOutput(finalRent);
        document.getElementById('lblMortgage')!.innerText = formatRupiahOutput(monthlyPayment);
        document.getElementById('lblFinalAssetVal')!.innerText = formatRupiahOutput(currentAssetValue);
        document.getElementById('lblTotalRentPaid')!.innerText = formatRupiahOutput(totalRentPaid);
        document.getElementById('lblFinalInvest')!.innerText = formatRupiahOutput(rentInvestment);

        const verdictBox = document.getElementById('verdictBox')!;
        const verdictTitle = document.getElementById('verdictTitle')!;
        const verdictDesc = document.getElementById('verdictDesc')!;
        const diff = Math.abs(finalBuy - finalRent);

        if (finalBuy > finalRent) {
            verdictBox.className = "p-4 rounded-xl border border-blue-200 bg-blue-50 text-blue-900";
            verdictTitle.innerText = "Membeli Finansialnya Lebih Baik!";
            verdictDesc.innerText = `Di akhir tahun ke-${loanTerm}, opsi membeli meninggalkan Anda dengan nilai ekuitas bersih lebih besar Rp ${formatRupiahOutput(diff)} dibanding menyewa.`;
        } else {
            verdictBox.className = "p-4 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-900";
            verdictTitle.innerText = "Menyewa Finansialnya Lebih Baik!";
            verdictDesc.innerText = `Di akhir tahun ke-${loanTerm}, menyewa dan mengalihkan dana ke investasi memberikan imbal hasil bersih lebih tinggi sebesar Rp ${formatRupiahOutput(diff)}.`;
        }

        renderChart(labels, buyTimeline, rentTimeline);
    }

    function renderChart(labels: string[], buyData: number[], rentData: number[]) {
        const canvas = document.getElementById('comparisonChart') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;
        
        if (chartInstance) chartInstance.destroy();

        chartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Ekuitas Hasil Beli (Nilai Aset - Sisa Utang)',
                        data: buyData,
                        borderColor: 'rgb(37, 99, 235)',
                        backgroundColor: 'rgba(37, 99, 235, 0.05)',
                        fill: true,
                        tension: 0.1
                    },
                    {
                        label: 'Nilai Portofolio Hasil Sewa + Investasi',
                        data: rentData,
                        borderColor: 'rgb(16, 185, 129)',
                        backgroundColor: 'rgba(16, 185, 129, 0.05)',
                        fill: true,
                        tension: 0.1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    tooltip: {
                        callbacks: { label: (context) => context.dataset.label + ': ' + formatRupiahOutput(context.raw as number) }
                    }
                },
                scales: {
                    y: {
                        ticks: {
                            callback: (value) => {
                                const valNum = value as number;
                                if (Math.abs(valNum) >= 1e9) return 'Rp ' + (valNum / 1e9).toFixed(1) + ' M';
                                if (Math.abs(valNum) >= 1e6) return 'Rp ' + (valNum / 1e6).toFixed(0) + ' Jt';
                                return valNum;
                            }
                        }
                    }
                }
            }
        });
    }

    // Fungsi menyimpan data ke localStorage
    function saveToLocalStorage() {
        const data = {
            assetType: (document.getElementById('assetType') as HTMLSelectElement)?.value || 'depreciating',
            assetPrice: (document.getElementById('assetPrice') as HTMLInputElement)?.value || '300.000.000',
            downPayment: (document.getElementById('downPayment') as HTMLInputElement)?.value || '60.000.000',
            loanInterest: (document.getElementById('loanInterest') as HTMLInputElement)?.value || '6',
            loanTerm: (document.getElementById('loanTerm') as HTMLInputElement)?.value || '5',
            assetGrowthRate: (document.getElementById('assetGrowthRate') as HTMLInputElement)?.value || '15',
            monthlyRent: (document.getElementById('monthlyRent') as HTMLInputElement)?.value || '6.000.000',
            investmentReturn: (document.getElementById('investmentReturn') as HTMLInputElement)?.value || '8'
        };
        localStorage.setItem('buyVsRentData', JSON.stringify(data));
    }

    // Fungsi memuat data dari localStorage
    function loadFromLocalStorage() {
        const savedData = localStorage.getItem('buyVsRentData');
        if (!savedData) return;

        try {
            const data = JSON.parse(savedData);
            
            const assetTypeEl = document.getElementById('assetType') as HTMLSelectElement;
            const assetPriceEl = document.getElementById('assetPrice') as HTMLInputElement;
            const downPaymentEl = document.getElementById('downPayment') as HTMLInputElement;
            const loanInterestEl = document.getElementById('loanInterest') as HTMLInputElement;
            const loanTermEl = document.getElementById('loanTerm') as HTMLInputElement;
            const assetGrowthRateEl = document.getElementById('assetGrowthRate') as HTMLInputElement;
            const monthlyRentEl = document.getElementById('monthlyRent') as HTMLInputElement;
            const investmentReturnEl = document.getElementById('investmentReturn') as HTMLInputElement;

            if (assetTypeEl) assetTypeEl.value = data.assetType || 'depreciating';
            if (assetPriceEl) assetPriceEl.value = data.assetPrice || '300.000.000';
            if (downPaymentEl) downPaymentEl.value = data.downPayment || '60.000.000';
            if (loanInterestEl) loanInterestEl.value = data.loanInterest || '6';
            if (loanTermEl) loanTermEl.value = data.loanTerm || '5';
            if (assetGrowthRateEl) assetGrowthRateEl.value = data.assetGrowthRate || '15';
            if (monthlyRentEl) monthlyRentEl.value = data.monthlyRent || '6.000.000';
            if (investmentReturnEl) investmentReturnEl.value = data.investmentReturn || '8';

            presetAssetType();
        } catch (e) {
            console.error('Error loading from localStorage:', e);
        }
    }

    // Fungsi reset ke default
    function resetToDefault() {
        if (!confirm('Apakah Anda yakin ingin mereset semua data ke kondisi default? Data yang tersimpan akan dihapus.')) {
            return;
        }

        localStorage.removeItem('buyVsRentData');

        const assetTypeEl = document.getElementById('assetType') as HTMLSelectElement;
        const assetPriceEl = document.getElementById('assetPrice') as HTMLInputElement;
        const downPaymentEl = document.getElementById('downPayment') as HTMLInputElement;
        const loanInterestEl = document.getElementById('loanInterest') as HTMLInputElement;
        const loanTermEl = document.getElementById('loanTerm') as HTMLInputElement;
        const assetGrowthRateEl = document.getElementById('assetGrowthRate') as HTMLInputElement;
        const monthlyRentEl = document.getElementById('monthlyRent') as HTMLInputElement;
        const investmentReturnEl = document.getElementById('investmentReturn') as HTMLInputElement;

        if (assetTypeEl) assetTypeEl.value = 'depreciating';
        if (assetPriceEl) assetPriceEl.value = '300.000.000';
        if (downPaymentEl) downPaymentEl.value = '60.000.000';
        if (loanInterestEl) loanInterestEl.value = '6';
        if (loanTermEl) loanTermEl.value = '5';
        if (assetGrowthRateEl) assetGrowthRateEl.value = '15';
        if (monthlyRentEl) monthlyRentEl.value = '6.000.000';
        if (investmentReturnEl) investmentReturnEl.value = '8';

        presetAssetType();
        calculate();
    }

    // Fungsi toggle section JSON
    function toggleJsonSection() {
        const jsonSection = document.getElementById('json-section');
        if (jsonSection) {
            jsonSection.classList.toggle('hidden');
        }
    }

    // Fungsi export data ke JSON
    function exportToJson() {
        const data = {
            assetType: (document.getElementById('assetType') as HTMLSelectElement)?.value || 'depreciating',
            assetPrice: (document.getElementById('assetPrice') as HTMLInputElement)?.value || '300.000.000',
            downPayment: (document.getElementById('downPayment') as HTMLInputElement)?.value || '60.000.000',
            loanInterest: (document.getElementById('loanInterest') as HTMLInputElement)?.value || '6',
            loanTerm: (document.getElementById('loanTerm') as HTMLInputElement)?.value || '5',
            assetGrowthRate: (document.getElementById('assetGrowthRate') as HTMLInputElement)?.value || '15',
            monthlyRent: (document.getElementById('monthlyRent') as HTMLInputElement)?.value || '6.000.000',
            investmentReturn: (document.getElementById('investmentReturn') as HTMLInputElement)?.value || '8'
        };

        const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
        if (jsonInput) {
            jsonInput.value = JSON.stringify(data, null, 2);
        }
    }

    // Fungsi import data dari JSON
    function importFromJson() {
        const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
        const errorEl = document.getElementById('json-error');
        
        if (!jsonInput || !jsonInput.value.trim()) {
            if (errorEl) {
                errorEl.textContent = 'JSON input tidak boleh kosong';
                errorEl.classList.remove('hidden');
            }
            return;
        }

        try {
            const data = JSON.parse(jsonInput.value);
            
            const assetTypeEl = document.getElementById('assetType') as HTMLSelectElement;
            const assetPriceEl = document.getElementById('assetPrice') as HTMLInputElement;
            const downPaymentEl = document.getElementById('downPayment') as HTMLInputElement;
            const loanInterestEl = document.getElementById('loanInterest') as HTMLInputElement;
            const loanTermEl = document.getElementById('loanTerm') as HTMLInputElement;
            const assetGrowthRateEl = document.getElementById('assetGrowthRate') as HTMLInputElement;
            const monthlyRentEl = document.getElementById('monthlyRent') as HTMLInputElement;
            const investmentReturnEl = document.getElementById('investmentReturn') as HTMLInputElement;

            if (assetTypeEl) assetTypeEl.value = data.assetType || 'depreciating';
            if (assetPriceEl) assetPriceEl.value = data.assetPrice || '300.000.000';
            if (downPaymentEl) downPaymentEl.value = data.downPayment || '60.000.000';
            if (loanInterestEl) loanInterestEl.value = data.loanInterest || '6';
            if (loanTermEl) loanTermEl.value = data.loanTerm || '5';
            if (assetGrowthRateEl) assetGrowthRateEl.value = data.assetGrowthRate || '15';
            if (monthlyRentEl) monthlyRentEl.value = data.monthlyRent || '6.000.000';
            if (investmentReturnEl) investmentReturnEl.value = data.investmentReturn || '8';

            presetAssetType();
            saveToLocalStorage();
            calculate();
            
            if (errorEl) {
                errorEl.classList.add('hidden');
            }

            const jsonSection = document.getElementById('json-section');
            if (jsonSection) {
                jsonSection.classList.add('hidden');
            }

            alert('Data berhasil di-import dari JSON!');

        } catch (e) {
            if (errorEl) {
                errorEl.textContent = `Error: ${(e as Error).message}`;
                errorEl.classList.remove('hidden');
            }
        }
    }

    // Fungsi clear JSON input
    function clearJsonInput() {
        const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
        const errorEl = document.getElementById('json-error');
        
        if (jsonInput) {
            jsonInput.value = '';
        }
        if (errorEl) {
            errorEl.classList.add('hidden');
        }
    }

    // Pendaftaran Event Listener untuk Real-time Input Masking (Titik Ribuan)
    function setupEventListeners() {
        const rupiahInputs = document.querySelectorAll('.rupiah-input');
        rupiahInputs.forEach(input => {
            input.addEventListener('input', (e) => {
                const target = e.target as HTMLInputElement;
                target.value = formatNumberWithDots(target.value);
                saveToLocalStorage();
            });
        });

        document.getElementById('assetType')?.addEventListener('change', () => {
            presetAssetType();
            saveToLocalStorage();
        });
        document.getElementById('btnCalculate')?.addEventListener('click', calculate);
        document.getElementById('btn-toggle-json')?.addEventListener('click', toggleJsonSection);
        document.getElementById('btn-import-json')?.addEventListener('click', importFromJson);
        document.getElementById('btn-export-json')?.addEventListener('click', exportToJson);
        document.getElementById('btn-clear-json')?.addEventListener('click', clearJsonInput);
        document.getElementById('btn-reset-data')?.addEventListener('click', resetToDefault);

        // Event listeners untuk auto-save pada input non-rupiah
        const nonRupiahInputs = document.querySelectorAll('#loanInterest, #loanTerm, #assetGrowthRate, #investmentReturn');
        nonRupiahInputs.forEach(input => {
            input.addEventListener('input', saveToLocalStorage);
        });

        // Eksekusi kalkulasi awal sewaktu komponen di-load
        loadFromLocalStorage();
        presetAssetType();
        calculate();
    }

    // Jalankan skrip baik pada load awal maupun setelah navigasi halaman Astro (View Transitions)
    setupEventListeners();
    document.addEventListener('astro:page-load', setupEventListeners);
</script>