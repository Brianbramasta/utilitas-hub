---
// Anda bisa mengimport layout global di sini jika perlu
// import Layout from '../layouts/Layout.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cost-Benefit Analysis (CBA) Calculator</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-white text-zinc-800 font-sans p-5 antialiased">

<div class="max-w-6xl mx-auto ">
    <div class="text-center mt-4 mb-8">
        <h1 class="text-3xl font-extrabold text-zinc-950 mt-3">Kalkulator Cost-Benefit Analysis (CBA)</h1>
        <p class="text-zinc-500 mt-1 font-medium">Bandingkan opsi keputusan berdasarkan bobot dampak (Value) dan probabilitas terjadinya (Probability).</p>
    </div>

    <div class="space-y-8" id="cba-workspace">
        </div>

    <div class="mt-6 flex flex-col sm:flex-row gap-4 ">
        <button id="btn-add-option" class="border border-dashed border-zinc-300 hover:border-zinc-400 bg-zinc-50/50 text-zinc-600 hover:text-zinc-950 text-sm py-3 px-4 rounded-xl cursor-pointer flex-1 transition font-medium text-center">
            + Tambah Opsi Keputusan Baru
        </button>
        <button id="btn-calculate" class="bg-zinc-900 hover:bg-zinc-800 text-white py-3 px-8 rounded-xl font-bold cursor-pointer transition duration-200 shadow-md sm:w-auto w-full">
            Hitung & Bandingkan Hasil
        </button>
    </div>

    <div class="mt-4">
        <button id="btn-toggle-json" class="border border-zinc-300 hover:border-zinc-400 text-zinc-500 hover:text-zinc-900 text-xs py-2 px-4 rounded-lg cursor-pointer w-full transition font-medium">
            📝 Import/Export JSON
        </button>
    </div>

    <div id="json-section" class="mt-4 hidden">
        <div class="bg-zinc-50 p-4 rounded-lg border border-zinc-200">
            <label class="block text-xs font-semibold text-zinc-500 mb-2">Import Data dari JSON:</label>
            <textarea id="json-input" class="w-full h-64 bg-white border border-zinc-200 rounded-lg p-3 text-xs text-zinc-700 font-mono outline-none focus:border-zinc-400 resize-y" placeholder='{
  "options": [
    {
      "name": "Opsi A",
      "benefits": [
        {"desc": "Benefit 1", "value": 3, "probability": 0.5}
      ],
      "costs": [
        {"desc": "Cost 1", "value": 2, "probability": 0.3}
      ]
    }
  ]
}'></textarea>
            <div class="flex gap-2 mt-3">
                <button id="btn-import-json" class="bg-blue-600 hover:bg-blue-500 text-white text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition flex-1">Import JSON</button>
                <button id="btn-export-json" class="bg-zinc-200 hover:bg-zinc-300 text-zinc-700 text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition flex-1">Export JSON</button>
                <button id="btn-clear-json" class="bg-red-100 hover:bg-red-200 text-red-700 text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition">Clear</button>
            </div>
            <div class="flex gap-2 mt-2">
                <button id="btn-reset-data" class="bg-orange-100 hover:bg-orange-200 text-orange-700 text-xs py-2 px-4 rounded-lg font-bold cursor-pointer transition w-full">🔄 Reset ke Default</button>
            </div>
            <p id="json-error" class="text-red-600 text-xs mt-2 hidden"></p>
        </div>
    </div>

    <div class="bg-zinc-50 p-6 rounded-xl border border-zinc-200 mt-8 shadow-sm hidden" id="result-section">
        <h2 class="text-xl font-bold text-zinc-950 mb-4 text-center">Rekomendasi Keputusan Terbaik</h2>
        <div id="ranking-list" class="flex flex-col gap-3"></div>
    </div>
</div>

<script>
    // State global aplikasi menggunakan variabel biasa
    let optionCounter = 0;

    // Fungsi menyimpan data ke localStorage
    function saveToLocalStorage() {
        const data: any = {
            options: []
        };

        document.querySelectorAll('.option-card').forEach(card => {
            const idStr = card.id.replace('option-card-', '');
            const currentId = parseInt(idStr);
            
            const optionNameInput = card.querySelector('.option-name');
            const optionName = optionNameInput ? (optionNameInput as HTMLInputElement).value : `Opsi Tanpa Nama #${currentId}`;

            const benefits: any[] = [];
            card.querySelectorAll(`#tbody-benefit-${currentId} tr`).forEach(row => {
                const descInput = row.querySelector('.item-desc');
                const valueInput = row.querySelector('.item-value');
                const probInput = row.querySelector('.item-probability');
                
                benefits.push({
                    desc: descInput ? (descInput as HTMLInputElement).value : '',
                    value: valueInput ? parseFloat((valueInput as HTMLInputElement).value) : 3,
                    probability: probInput ? parseFloat((probInput as HTMLInputElement).value) : 0.5
                });
            });

            const costs: any[] = [];
            card.querySelectorAll(`#tbody-cost-${currentId} tr`).forEach(row => {
                const descInput = row.querySelector('.item-desc');
                const valueInput = row.querySelector('.item-value');
                const probInput = row.querySelector('.item-probability');
                
                costs.push({
                    desc: descInput ? (descInput as HTMLInputElement).value : '',
                    value: valueInput ? parseFloat((valueInput as HTMLInputElement).value) : 3,
                    probability: probInput ? parseFloat((probInput as HTMLInputElement).value) : 0.5
                });
            });

            data.options.push({
                name: optionName,
                benefits: benefits,
                costs: costs
            });
        });

        localStorage.setItem('cbaData', JSON.stringify(data));
    }

    // Fungsi memuat data dari localStorage
    function loadFromLocalStorage() {
        const savedData = localStorage.getItem('cbaData');
        if (!savedData) return;

        try {
            const data = JSON.parse(savedData);
            
            // Reset form
            const workspace = document.getElementById('cba-workspace');
            if (workspace) workspace.innerHTML = '';
            optionCounter = 0;

            // Restore options
            if (data.options && Array.isArray(data.options)) {
                data.options.forEach((opt: any) => {
                    const benefitDescs = opt.benefits ? opt.benefits.map((b: any) => b.desc || '') : [''];
                    const costDescs = opt.costs ? opt.costs.map((c: any) => c.desc || '') : [''];
                    
                    renderOptionCard(opt.name || 'Opsi Tanpa Nama', benefitDescs, costDescs);
                    
                    // Restore option name display
                    const cardId = document.querySelectorAll('.option-card').length;
                    const card = document.getElementById(`option-card-${cardId}`);
                    if (card) {
                        const optionNameInput = card.querySelector('.option-name');
                        if (optionNameInput) {
                            (optionNameInput as HTMLInputElement).value = opt.name || 'Opsi Tanpa Nama';
                            // Update display element
                            const parent = optionNameInput.parentElement;
                            const displayEl = parent?.querySelector('.option-name-display');
                            if (displayEl) displayEl.textContent = opt.name || 'Opsi Tanpa Nama';
                        }
                    }
                    
                    // Restore benefit values
                    const tbodyBenefit = document.getElementById(`tbody-benefit-${cardId}`);
                    if (tbodyBenefit && opt.benefits) {
                        const rows = tbodyBenefit.querySelectorAll('tr');
                        opt.benefits.forEach((b: any, idx: number) => {
                            if (rows[idx]) {
                                const descInput = rows[idx].querySelector('.item-desc');
                                const valueInput = rows[idx].querySelector('.item-value');
                                const probInput = rows[idx].querySelector('.item-probability');
                                
                                if (descInput) {
                                    (descInput as HTMLInputElement).value = b.desc || '';
                                    // Update display element
                                    const parent = descInput.parentElement;
                                    const displayEl = parent?.querySelector('.item-desc-display');
                                    if (displayEl) displayEl.textContent = b.desc || 'Nama komponen analisis...';
                                }
                                if (valueInput) {
                                    (valueInput as HTMLInputElement).value = b.value || 3;
                                    // Update display element
                                    const parent = valueInput.parentElement;
                                    const displayEl = parent?.querySelector('.item-value-display');
                                    if (displayEl) displayEl.textContent = (b.value || 3).toString();
                                }
                                if (probInput) {
                                    (probInput as HTMLInputElement).value = b.probability || 0.5;
                                    // Update display element
                                    const parent = probInput.parentElement;
                                    const displayEl = parent?.querySelector('.item-probability-display');
                                    if (displayEl) displayEl.textContent = (b.probability || 0.5).toFixed(2);
                                }
                                
                                // Recalculate score
                                if (valueInput) (window as any).calculateItemScore(valueInput);
                            }
                        });
                    }

                    // Restore cost values
                    const tbodyCost = document.getElementById(`tbody-cost-${cardId}`);
                    if (tbodyCost && opt.costs) {
                        const rows = tbodyCost.querySelectorAll('tr');
                        opt.costs.forEach((c: any, idx: number) => {
                            if (rows[idx]) {
                                const descInput = rows[idx].querySelector('.item-desc');
                                const valueInput = rows[idx].querySelector('.item-value');
                                const probInput = rows[idx].querySelector('.item-probability');
                                
                                if (descInput) {
                                    (descInput as HTMLInputElement).value = c.desc || '';
                                    // Update display element
                                    const parent = descInput.parentElement;
                                    const displayEl = parent?.querySelector('.item-desc-display');
                                    if (displayEl) displayEl.textContent = c.desc || 'Nama komponen analisis...';
                                }
                                if (valueInput) {
                                    (valueInput as HTMLInputElement).value = c.value || 3;
                                    // Update display element
                                    const parent = valueInput.parentElement;
                                    const displayEl = parent?.querySelector('.item-value-display');
                                    if (displayEl) displayEl.textContent = (c.value || 3).toString();
                                }
                                if (probInput) {
                                    (probInput as HTMLInputElement).value = c.probability || 0.5;
                                    // Update display element
                                    const parent = probInput.parentElement;
                                    const displayEl = parent?.querySelector('.item-probability-display');
                                    if (displayEl) displayEl.textContent = (c.probability || 0.5).toFixed(2);
                                }
                                
                                // Recalculate score
                                if (valueInput) (window as any).calculateItemScore(valueInput);
                            }
                        });
                    }
                });
            }
        } catch (e) {
            console.error('Error loading from localStorage:', e);
        }
    }

    // Fungsi toggle section JSON
    function toggleJsonSection() {
        const jsonSection = document.getElementById('json-section');
        if (jsonSection) {
            jsonSection.classList.toggle('hidden');
        }
    }

    // Fungsi export data ke JSON
    function exportToJson() {
        const data: any = {
            options: []
        };

        document.querySelectorAll('.option-card').forEach(card => {
            const idStr = card.id.replace('option-card-', '');
            const currentId = parseInt(idStr);
            
            const optionNameInput = card.querySelector('.option-name');
            const optionName = optionNameInput ? (optionNameInput as HTMLInputElement).value : `Opsi Tanpa Nama #${currentId}`;

            const benefits: any[] = [];
            card.querySelectorAll(`#tbody-benefit-${currentId} tr`).forEach(row => {
                const descInput = row.querySelector('.item-desc');
                const valueInput = row.querySelector('.item-value');
                const probInput = row.querySelector('.item-probability');
                
                benefits.push({
                    desc: descInput ? (descInput as HTMLInputElement).value : '',
                    value: valueInput ? parseFloat((valueInput as HTMLInputElement).value) : 3,
                    probability: probInput ? parseFloat((probInput as HTMLInputElement).value) : 0.5
                });
            });

            const costs: any[] = [];
            card.querySelectorAll(`#tbody-cost-${currentId} tr`).forEach(row => {
                const descInput = row.querySelector('.item-desc');
                const valueInput = row.querySelector('.item-value');
                const probInput = row.querySelector('.item-probability');
                
                costs.push({
                    desc: descInput ? (descInput as HTMLInputElement).value : '',
                    value: valueInput ? parseFloat((valueInput as HTMLInputElement).value) : 3,
                    probability: probInput ? parseFloat((probInput as HTMLInputElement).value) : 0.5
                });
            });

            data.options.push({
                name: optionName,
                benefits: benefits,
                costs: costs
            });
        });

        const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
        if (jsonInput) {
            jsonInput.value = JSON.stringify(data, null, 2);
        }
    }

    // Fungsi import data dari JSON
    function importFromJson() {
        const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
        const errorEl = document.getElementById('json-error');
        
        if (!jsonInput || !jsonInput.value.trim()) {
            if (errorEl) {
                errorEl.textContent = 'JSON input tidak boleh kosong';
                errorEl.classList.remove('hidden');
            }
            return;
        }

        try {
            const data = JSON.parse(jsonInput.value);
            
            // Validasi struktur JSON
            if (!data.options || !Array.isArray(data.options)) {
                throw new Error('Struktur JSON tidak valid. Harus mengandung options array');
            }

            if (data.options.length === 0) {
                throw new Error('Minimal harus ada 1 opsi');
            }

            // Reset form
            const workspace = document.getElementById('cba-workspace');
            if (workspace) workspace.innerHTML = '';
            optionCounter = 0;

            // Restore options
            data.options.forEach((opt: any) => {
                const benefitDescs = opt.benefits ? opt.benefits.map((b: any) => b.desc || '') : [''];
                const costDescs = opt.costs ? opt.costs.map((c: any) => c.desc || '') : [''];
                
                renderOptionCard(opt.name || 'Opsi Tanpa Nama', benefitDescs, costDescs);
                
                // Restore option name display
                const importCardId = document.querySelectorAll('.option-card').length;
                const card = document.getElementById(`option-card-${importCardId}`);
                if (card) {
                    const optionNameInput = card.querySelector('.option-name');
                    if (optionNameInput) {
                        (optionNameInput as HTMLInputElement).value = opt.name || 'Opsi Tanpa Nama';
                        // Update display element
                        const parent = optionNameInput.parentElement;
                        const displayEl = parent?.querySelector('.option-name-display');
                        if (displayEl) displayEl.textContent = opt.name || 'Opsi Tanpa Nama';
                    }
                }
                
                // Restore benefit values
                const tbodyBenefit = document.getElementById(`tbody-benefit-${importCardId}`);
                if (tbodyBenefit && opt.benefits) {
                    const rows = tbodyBenefit.querySelectorAll('tr');
                    opt.benefits.forEach((b: any, idx: number) => {
                        if (rows[idx]) {
                            const descInput = rows[idx].querySelector('.item-desc');
                            const valueInput = rows[idx].querySelector('.item-value');
                            const probInput = rows[idx].querySelector('.item-probability');
                            
                            if (descInput) {
                                (descInput as HTMLInputElement).value = b.desc || '';
                                // Update display element
                                const parent = descInput.parentElement;
                                const displayEl = parent?.querySelector('.item-desc-display');
                                if (displayEl) displayEl.textContent = b.desc || 'Nama komponen analisis...';
                            }
                            if (valueInput) {
                                (valueInput as HTMLInputElement).value = b.value || 3;
                                // Update display element
                                const parent = valueInput.parentElement;
                                const displayEl = parent?.querySelector('.item-value-display');
                                if (displayEl) displayEl.textContent = (b.value || 3).toString();
                            }
                            if (probInput) {
                                (probInput as HTMLInputElement).value = b.probability || 0.5;
                                // Update display element
                                const parent = probInput.parentElement;
                                const displayEl = parent?.querySelector('.item-probability-display');
                                if (displayEl) displayEl.textContent = (b.probability || 0.5).toFixed(2);
                            }
                            
                            // Recalculate score
                            if (valueInput) (window as any).calculateItemScore(valueInput);
                        }
                    });
                }

                // Restore cost values
                const tbodyCost = document.getElementById(`tbody-cost-${importCardId}`);
                if (tbodyCost && opt.costs) {
                    const rows = tbodyCost.querySelectorAll('tr');
                    opt.costs.forEach((c: any, idx: number) => {
                        if (rows[idx]) {
                            const descInput = rows[idx].querySelector('.item-desc');
                            const valueInput = rows[idx].querySelector('.item-value');
                            const probInput = rows[idx].querySelector('.item-probability');
                            
                            if (descInput) {
                                (descInput as HTMLInputElement).value = c.desc || '';
                                // Update display element
                                const parent = descInput.parentElement;
                                const displayEl = parent?.querySelector('.item-desc-display');
                                if (displayEl) displayEl.textContent = c.desc || 'Nama komponen analisis...';
                            }
                            if (valueInput) {
                                (valueInput as HTMLInputElement).value = c.value || 3;
                                // Update display element
                                const parent = valueInput.parentElement;
                                const displayEl = parent?.querySelector('.item-value-display');
                                if (displayEl) displayEl.textContent = (c.value || 3).toString();
                            }
                            if (probInput) {
                                (probInput as HTMLInputElement).value = c.probability || 0.5;
                                // Update display element
                                const parent = probInput.parentElement;
                                const displayEl = parent?.querySelector('.item-probability-display');
                                if (displayEl) displayEl.textContent = (c.probability || 0.5).toFixed(2);
                            }
                            
                            // Recalculate score
                            if (valueInput) (window as any).calculateItemScore(valueInput);
                        }
                    });
                }
            });

            saveToLocalStorage();
            
            // Hide error jika ada
            if (errorEl) {
                errorEl.classList.add('hidden');
            }

            // Hide JSON section setelah import berhasil
            const jsonSection = document.getElementById('json-section');
            if (jsonSection) {
                jsonSection.classList.add('hidden');
            }

            alert('Data berhasil di-import dari JSON!');

        } catch (e) {
            if (errorEl) {
                errorEl.textContent = `Error: ${(e as Error).message}`;
                errorEl.classList.remove('hidden');
            }
        }
    }

    // Fungsi clear JSON input
    function clearJsonInput() {
        const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
        const errorEl = document.getElementById('json-error');
        
        if (jsonInput) {
            jsonInput.value = '';
        }
        if (errorEl) {
            errorEl.classList.add('hidden');
        }
    }

    // Fungsi reset ke default
    function resetToDefault() {
        if (!confirm('Apakah Anda yakin ingin mereset semua data ke kondisi default? Data yang tersimpan akan dihapus.')) {
            return;
        }

        // Hapus data dari localStorage
        localStorage.removeItem('cbaData');

        // Reset form
        const workspace = document.getElementById('cba-workspace');
        if (workspace) workspace.innerHTML = '';
        optionCounter = 0;

        // Sembunyikan hasil
        const resultSection = document.getElementById('result-section');
        if (resultSection) resultSection.classList.add('hidden');

        // Reset ke default: 1 opsi kosong
        addNewOptionBlank();
    }

    // Inisialisasi awal tanpa dummy data (bersih) saat DOM siap
    document.addEventListener('DOMContentLoaded', () => {
        // Load dari localStorage
        loadFromLocalStorage();
        
        // Jika tidak ada data, buat 1 opsi kosong pertama
        if (document.querySelectorAll('.option-card').length === 0) {
            addNewOptionBlank();
        }

        // Pasang Event Listener Tombol Utama
        const addOptionBtn = document.getElementById('btn-add-option');
        if (addOptionBtn) {
            addOptionBtn.addEventListener('click', () => addNewOptionBlank());
        }
        const calculateBtn = document.getElementById('btn-calculate');
        if (calculateBtn) {
            calculateBtn.addEventListener('click', calculateCBA);
        }
        const toggleJsonBtn = document.getElementById('btn-toggle-json');
        if (toggleJsonBtn) {
            toggleJsonBtn.addEventListener('click', toggleJsonSection);
        }
        const importJsonBtn = document.getElementById('btn-import-json');
        if (importJsonBtn) {
            importJsonBtn.addEventListener('click', importFromJson);
        }
        const exportJsonBtn = document.getElementById('btn-export-json');
        if (exportJsonBtn) {
            exportJsonBtn.addEventListener('click', exportToJson);
        }
        const clearJsonBtn = document.getElementById('btn-clear-json');
        if (clearJsonBtn) {
            clearJsonBtn.addEventListener('click', clearJsonInput);
        }
        const resetDataBtn = document.getElementById('btn-reset-data');
        if (resetDataBtn) {
            resetDataBtn.addEventListener('click', resetToDefault);
        }
    });

    // Event listeners untuk auto-save
    document.addEventListener('input', (e) => {
        const target = e.target as HTMLElement;
        if (target.classList.contains('option-name') || 
            target.classList.contains('item-desc') || 
            target.classList.contains('item-value') || 
            target.classList.contains('item-probability')) {
            saveToLocalStorage();
        }
    });

    // Event listener untuk tombol hapus
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.tagName === 'BUTTON' && target.textContent === '×') {
            setTimeout(saveToLocalStorage, 100);
        }
    });

    // Ekspos fungsi manipulasi ke scope window global agar bisa dipanggil dari inline attribute HTML
    (window as any).addItemRow = function(optionId: number, type: string) {
        const tbody = document.getElementById(`tbody-${type}-${optionId}`);
        if (tbody) {
            tbody.appendChild(createRowHTML('', 3, 0.5));
        }
    };

    (window as any).removeItemRow = function(button: HTMLElement) {
        const row = button.closest('tr');
        const tbody = row ? row.closest('tbody') : null;
        if (tbody && tbody.querySelectorAll('tr').length <= 1) {
            alert("Minimal harus ada 1 baris analisis.");
            return;
        }
        if (row) row.remove();
    };

    (window as any).deleteOption = function(optionId: number) {
        if (document.querySelectorAll('.option-card').length <= 1) {
            alert("Minimal harus menyisakan 1 Opsi Keputusan.");
            return;
        }
        if (confirm("Apakah Anda yakin ingin menghapus opsi ini?")) {
            const card = document.getElementById(`option-card-${optionId}`);
            if (card) card.remove();
            hideResultSection();
        }
    };

    (window as any).calculateItemScore = function(input: HTMLInputElement) {
        const row = input.closest('tr');
        if (!row) return;
        
        const valInp = row.querySelector('.item-value');
        const probInp = row.querySelector('.item-probability');
        const scoreEl = row.querySelector('.item-score');

        const valInpEl = valInp as HTMLInputElement;
        const probInpEl = probInp as HTMLInputElement;
        let val = parseFloat(valInpEl.value) || 0;
        let prob = parseFloat(probInpEl.value) || 0;

        // Validasi batasan input nilai
        if (val > 5) { val = 5; valInpEl.value = '5'; }
        if (val < 1) { val = 1; valInpEl.value = '1'; }
        if (prob > 1) { prob = 1; probInpEl.value = '1'; }
        if (prob < 0) { prob = 0; probInpEl.value = '0'; }

        const score = val * prob;
        if (scoreEl) (scoreEl as HTMLElement).innerText = score.toFixed(2);
    };

    // Fungsi mengkonversi input ke text display
    (window as any).convertToText = function(input: any, type: string) {
        const value = input.value;
        const parent = input.parentElement;
        
        let displayEl: HTMLElement | null = null;
        if (type === 'option-name') {
            displayEl = parent?.querySelector('.option-name-display') || null;
        } else if (type === 'item-desc') {
            displayEl = parent?.querySelector('.item-desc-display') || null;
        } else if (type === 'item-value') {
            displayEl = parent?.querySelector('.item-value-display') || null;
        } else if (type === 'item-probability') {
            displayEl = parent?.querySelector('.item-probability-display') || null;
        }

        if (displayEl) {
            displayEl.textContent = value;
            displayEl.classList.remove('hidden');
            input.classList.add('hidden');
            saveToLocalStorage();
        }
    };

    // Fungsi mengkonversi text display ke input
    (window as any).convertToInput = function(displayEl: HTMLElement, type: string) {
        const parent = displayEl.parentElement;
        
        let input: HTMLInputElement | null = null;
        if (type === 'option-name') {
            input = parent?.querySelector('.option-name') || null;
        } else if (type === 'item-desc') {
            input = parent?.querySelector('.item-desc') || null;
        } else if (type === 'item-value') {
            input = parent?.querySelector('.item-value') || null;
        } else if (type === 'item-probability') {
            input = parent?.querySelector('.item-probability') || null;
        }

        if (input) {
            input.classList.remove('hidden');
            displayEl.classList.add('hidden');
            input.focus();
            input.select();
        }
    };

    function hideResultSection() {
        const resultSection = document.getElementById('result-section');
        if (resultSection) resultSection.classList.add('hidden');
    }

    // Fungsi pembuat baris input baru berupa elemen TR
    function createRowHTML(desc = '', val = 3, prob = 0.5) {
        const tr = document.createElement('tr');
        tr.className = "border-b border-zinc-100 hover:bg-zinc-50/50";
        
        const score = val * prob;

        tr.innerHTML = `
            <td class="p-2">
                <span class="item-desc-display text-zinc-800 text-xs sm:text-sm cursor-pointer hover:text-zinc-600 break-words" onclick="window.convertToInput(this, 'item-desc')">${desc || 'Nama komponen analisis...'}</span>
                <input type="text" class="item-desc bg-transparent border-b border-zinc-200 focus:border-zinc-400 outline-none w-full text-zinc-800 text-xs sm:text-sm hidden" value="${desc}" placeholder="Nama komponen analisis..." onblur="window.convertToText(this, 'item-desc')" onkeydown="if(event.key === 'Enter') { this.blur(); }">
            </td>
            <td class="p-2 w-20">
                <span class="item-value-display text-center text-zinc-800 text-xs sm:text-sm cursor-pointer hover:text-zinc-600" onclick="window.convertToInput(this, 'item-value')">${val}</span>
                <input type="number" class="item-value bg-zinc-50 border border-zinc-200 text-center rounded p-1 w-full text-zinc-800 outline-none text-xs sm:text-sm focus:border-zinc-400 hidden" value="${val}" min="1" max="5" step="1" onchange="window.calculateItemScore(this)" onblur="window.convertToText(this, 'item-value')" onkeydown="if(event.key === 'Enter') { this.blur(); }">
            </td>
            <td class="p-2 w-24">
                <span class="item-probability-display text-center text-zinc-800 text-xs sm:text-sm cursor-pointer hover:text-zinc-600" onclick="window.convertToInput(this, 'item-probability')">${prob.toFixed(2)}</span>
                <input type="number" class="item-probability bg-zinc-50 border border-zinc-200 text-center rounded p-1 w-full text-zinc-800 outline-none text-xs sm:text-sm focus:border-zinc-400 hidden" value="${prob.toFixed(2)}" min="0" max="1" step="0.1" onchange="window.calculateItemScore(this)" onblur="window.convertToText(this, 'item-probability')" onkeydown="if(event.key === 'Enter') { this.blur(); }">
            </td>
            <td class="p-2 w-20 text-right font-mono text-xs sm:text-sm font-bold text-zinc-600 item-score">
                ${score.toFixed(2)}
            </td>
            <td class="p-2 w-12 text-center">
                <button onclick="window.removeItemRow(this)" class="text-zinc-400 hover:text-red-500 transition cursor-pointer font-bold text-sm" title="Hapus Baris">×</button>
            </td>
        `;
        return tr;
    }

    // Render komponen kartu opsi ke workspace DOM
    function renderOptionCard(title: string, benefits: string[], costs: string[]) {
        optionCounter++;
        const workspace = document.getElementById('cba-workspace');
        if (!workspace) return;

        const card = document.createElement('div');
        card.id = `option-card-${optionCounter}`;
        card.className = "bg-white p-4 sm:p-6 rounded-xl border border-zinc-200 shadow-xs option-card relative group";

        card.innerHTML = `
            <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 mb-4 pb-2 border-b border-zinc-100">
                <span class="option-name-display font-extrabold text-lg sm:text-xl text-zinc-900 cursor-pointer hover:text-zinc-600 break-words w-full sm:w-2/3" onclick="window.convertToInput(this, 'option-name')">${title}</span>
                <input type="text" class="option-name bg-transparent font-extrabold text-lg sm:text-xl border-b border-transparent focus:border-zinc-400 outline-none text-zinc-900 w-full sm:w-2/3 hidden" value="${title}" onblur="window.convertToText(this, 'option-name')" onkeydown="if(event.key === 'Enter') { this.blur(); }">
                <button onclick="window.deleteOption(${optionCounter})" class="text-xs text-red-600 hover:bg-red-50 border border-red-200 px-2.5 py-1 rounded-md cursor-pointer transition sm:opacity-0 group-hover:opacity-100 self-start sm:self-center">
                    Hapus Opsi
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <div class="flex justify-between items-center bg-emerald-50 border border-emerald-100 p-2 rounded-lg">
                        <h3 class="text-sm font-bold text-emerald-700 uppercase tracking-wider">🟢 Potensi Benefit (Keuntungan)</h3>
                        <button onclick="window.addItemRow(${optionCounter}, 'benefit')" class="bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] py-1 px-2 rounded cursor-pointer transition font-bold">+ Benefit</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-[11px] text-zinc-400 uppercase tracking-wider border-b border-zinc-100">
                                    <th class="p-2 font-semibold">Faktor Kebaikan</th>
                                    <th class="p-2 text-center font-semibold">Value (1-5)</th>
                                    <th class="p-2 text-center font-semibold">Prob (0-1)</th>
                                    <th class="p-2 text-right font-semibold">Skor</th>
                                    <th class="p-2"></th>
                                </tr>
                            </thead>
                            <tbody id="tbody-benefit-${optionCounter}"></tbody>
                        </table>
                    </div>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center bg-red-50 border border-red-100 p-2 rounded-lg">
                        <h3 class="text-sm font-bold text-red-700 uppercase tracking-wider">🔴 Potensi Cost (Konsekuensi / Risiko)</h3>
                        <button onclick="window.addItemRow(${optionCounter}, 'cost')" class="bg-red-600 hover:bg-red-700 text-white text-[11px] py-1 px-2 rounded cursor-pointer transition font-bold">+ Cost</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-[11px] text-zinc-400 uppercase tracking-wider border-b border-zinc-100">
                                    <th class="p-2 font-semibold">Faktor Kerugian</th>
                                    <th class="p-2 text-center font-semibold">Value (1-5)</th>
                                    <th class="p-2 text-center font-semibold">Prob (0-1)</th>
                                    <th class="p-2 text-right font-semibold">Skor</th>
                                    <th class="p-2"></th>
                                </tr>
                            </thead>
                            <tbody id="tbody-cost-${optionCounter}"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        `;

        workspace.appendChild(card);

        // Isi baris data benefit awal
        const tbodyBenefit = document.getElementById(`tbody-benefit-${optionCounter}`);
        if (tbodyBenefit) {
            benefits.forEach(b => tbodyBenefit.appendChild(createRowHTML(b, 3, 0.5)));
        }

        // Isi baris data cost awal
        const tbodyCost = document.getElementById(`tbody-cost-${optionCounter}`);
        if (tbodyCost) {
            costs.forEach(c => tbodyCost.appendChild(createRowHTML(c, 3, 0.5)));
        }
    }

    function addNewOptionBlank() {
        const nextIdx = document.querySelectorAll('.option-card').length + 1;
        renderOptionCard(`Opsi Keputusan Baru ${nextIdx}`, 
            [''],
            ['']
        );
        hideResultSection();
    }

    // Fungsi Inti Kalkulasi & Pembandingan CBA
    function calculateCBA() {
        const optionCards = document.querySelectorAll('.option-card');
        interface OptionResult {
            id: number;
            name: string;
            totalBenefit: number;
            totalCost: number;
            netScore: number;
        }
        const results: OptionResult[] = [];

        optionCards.forEach(card => {
            const idStr = card.id.replace('option-card-', '');
            const currentId = parseInt(idStr);
            
            const optionNameInput = card.querySelector('.option-name');
            const optionName = optionNameInput ? (optionNameInput as HTMLInputElement).value : `Opsi Tanpa Nama #${currentId}`;

            // Akumulasi Total Benefit
            let totalBenefit = 0;
            card.querySelectorAll(`#tbody-benefit-${currentId} tr`).forEach(row => {
                const scoreEl = row.querySelector('.item-score');
                totalBenefit += parseFloat(scoreEl ? (scoreEl as HTMLElement).textContent : '0');
            });

            // Akumulasi Total Cost
            let totalCost = 0;
            card.querySelectorAll(`#tbody-cost-${currentId} tr`).forEach(row => {
                const scoreEl = row.querySelector('.item-score');
                totalCost += parseFloat(scoreEl ? (scoreEl as HTMLElement).textContent : '0');
            });

            const netScore = totalBenefit - totalCost;

            results.push({
                id: currentId,
                name: optionName,
                totalBenefit: totalBenefit,
                totalCost: totalCost,
                netScore: Math.round((netScore + Number.EPSILON) * 100) / 100
            });
        });

        // Urutkan dari Net Score tertinggi ke terendah
        results.sort((a, b) => b.netScore - a.netScore);

        // Render hasil perbandingan peringkat
        const rankListDiv = document.getElementById('ranking-list');
        if (rankListDiv) {
            rankListDiv.innerHTML = '';

            results.forEach((item, index) => {
                const isWinner = index === 0;
                
                const itemClass = isWinner 
                    ? "flex flex-col sm:flex-row justify-between sm:items-center p-4 border rounded-xl bg-emerald-50 text-emerald-950 border-emerald-200 font-bold shadow-xs ring-2 ring-emerald-500/10" 
                    : "flex flex-col sm:flex-row justify-between sm:items-center p-4 border rounded-xl bg-white text-zinc-500 border-zinc-200 shadow-xs";
                
                const badgeClass = isWinner 
                    ? "bg-emerald-600 text-white text-[10px] px-2 py-0.5 rounded font-black tracking-wider uppercase self-start"
                    : "bg-zinc-100 text-zinc-500 text-[10px] px-2 py-0.5 rounded font-bold tracking-wider uppercase self-start";

                const icon = isWinner ? '🏆 ' : '';
                const scoreColor = item.netScore >= 0 ? 'text-emerald-600' : 'text-red-600';

                rankListDiv.innerHTML += `
                    <div class="${itemClass}">
                        <div class="flex flex-col gap-1.5">
                            <span class="${badgeClass}">Rekomendasi ${index + 1}</span>
                            <span class="text-zinc-900 text-base font-extrabold">${icon}${item.name}</span>
                            <div class="text-[11px] font-medium text-zinc-500 space-x-3">
                                <span>Total Benefit: <span class="text-emerald-600 font-mono font-bold">${item.totalBenefit.toFixed(2)}</span></span>
                                <span>Total Cost: <span class="text-red-600 font-mono font-bold">${item.totalCost.toFixed(2)}</span></span>
                            </div>
                        </div>
                        <div class="text-left sm:text-right mt-2 sm:mt-0 border-t sm:border-t-0 border-zinc-100 pt-2 sm:pt-0">
                            <span class="text-xs text-zinc-400 block">Net Value Score</span>
                            <strong class="font-mono text-2xl ${scoreColor}">${item.netScore > 0 ? '+' : ''}${item.netScore.toFixed(2)}</strong>
                        </div>
                    </div>
                `;
            });
        }

        const resultSection = document.getElementById('result-section');
        if (resultSection) {
            resultSection.classList.remove('hidden');
            resultSection.scrollIntoView({ behavior: 'smooth' });
        }
    }
</script>

</body>
</html>