---
// Anda bisa membungkus komponen ini di dalam Layout bawaan Astro jika diperlukan
// Contoh: import BaseLayout from '../layouts/BaseLayout.astro';
---

<div class="bg-slate-50 text-slate-800 min-h-screen py-10 px-4 flex justify-center items-start">
    <div class="w-full max-w-2xl bg-white p-6 md:p-8 rounded-2xl shadow-lg border border-slate-100">
        <h2 class="text-2xl font-bold text-center text-amber-600 mb-2 flex items-center justify-center gap-2">
             Masak Sendiri vs Beli di Luar 
        </h2>
        <p class="text-sm text-slate-500 text-center mb-6">Hitung perbandingan biaya makan harian Anda secara akurat.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-1 gap-6">
            <div class="p-4 bg-amber-50/50 rounded-xl border border-amber-200">
                <h3 class="font-bold text-amber-800 mb-3 border-b border-amber-200 pb-2 flex items-center gap-1">
                    Opsi 1: Masak Sendiri
                </h3>
                <div class="space-y-3 text-xs text-slate-600">
                    <div>
                        <label class="block font-semibold mb-1">Harga Beras per 1 Kg (Rp)</label>
                        <input type="text" id="rice-price" value="15.000" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 money-input">
                        <span class="text-[10px] text-slate-400 mt-0.5 block">*1 Kg beras menghasilkan ~11 porsi nasi matang</span>
                    </div>
                    <div>
                        <label class="block font-semibold mb-1">Total Belanja Lauk & Sayur (Rp)</label>
                        <input type="text" id="side-price" placeholder="Contoh: 50.000" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 money-input">
                    </div>
                    <div>
                        <label class="block font-semibold mb-1">Untuk Berapa Porsi Makan Lauk Tersebut?</label>
                        <input type="number" id="side-portions" placeholder="Contoh: 6" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500">
                    </div>
                    <div>
                        <label class="block font-semibold mb-1">Estimasi Gas/Air/Listrik per Porsi (Rp)</label>
                        <input type="text" id="overhead-price" value="1.000" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 money-input">
                    </div>
                </div>
            </div>

            <div class="p-4 bg-blue-50/50 rounded-xl border border-blue-200 flex flex-col justify-between">
                <div>
                    <h3 class="font-bold text-blue-800 mb-3 border-b border-blue-200 pb-2 flex items-center gap-1">
                        Opsi 2: Beli di Luar
                    </h3>
                    <div class="space-y-3 text-xs text-slate-600">
                        <div>
                            <label class="block font-semibold mb-1">Harga 1 Porsi Makanan di Luar (Rp)</label>
                            <input type="text" id="outside-price" placeholder="Contoh: 15.000" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 money-input">
                            <span class="text-[10px] text-slate-400 mt-0.5 block">*Harga rata-rata sekali makan di warung/resto sekitar</span>
                        </div>
                    </div>
                </div>
                <div class="mt-6 p-3 bg-white rounded-lg border border-blue-100 text-xs text-slate-500">
                    <strong>Tips Realistis:</strong> Masak sendiri biasanya jauh lebih hemat jika porsi lauk dibuat untuk makan <strong>minimal 2-3 kali sehari</strong> atau dimakan bersama keluarga.
                </div>
            </div>
        </div>

        <button type="button" id="calc-btn" class="w-full mt-6 px-4 py-3 bg-slate-700 text-white font-semibold rounded-xl hover:bg-slate-800 transition shadow-md text-base">
            Hitung & Bandingkan Pengeluaran
        </button>

        <div id="result-box" class="mt-6 p-5 rounded-xl hidden text-sm border">
            </div>
    </div>
</div>

<script>
    // Format otomatis tanda titik ribuan saat mengetik uang
    function formatNumber(value: string) {
        if (!value) return "";
        const clean = value.replace(/\D/g, "");
        return clean.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    }

    function getRawValue(id: string) {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (!el || !el.value) return 0;
        return parseFloat(el.value.replace(/\./g, "")) || 0;
    }

    // Event listener untuk memformat input secara real-time
    document.addEventListener("input", function(e) {
        const target = e.target as HTMLInputElement;
        if (target && target.classList.contains("money-input")) {
            target.value = formatNumber(target.value);
        }
    });

    // Inisialisasi awal nilai default input element
    const ricePriceInput = document.getElementById('rice-price') as HTMLInputElement | null;
    const overheadPriceInput = document.getElementById('overhead-price') as HTMLInputElement | null;
    const calcButton = document.getElementById('calc-btn');

    if (ricePriceInput) ricePriceInput.value = formatNumber(ricePriceInput.value);
    if (overheadPriceInput) overheadPriceInput.value = formatNumber(overheadPriceInput.value);

    // Fungsi Utama Perbandingan
    function compareCookingCost() {
        const priceRice = getRawValue('rice-price');
        const priceSide = getRawValue('side-price');
        const sidePortionsInput = document.getElementById('side-portions') as HTMLInputElement | null;
        const sidePortions = parseFloat(sidePortionsInput?.value || "0") || 0;
        const priceOverhead = getRawValue('overhead-price');
        const priceOutside = getRawValue('outside-price');

        if (!priceRice || !priceSide || !sidePortions || !priceOutside) {
            alert("Harap lengkapi semua data inputan terlebih dahulu!");
            return;
        }

        // 1. Kalkulasi matematika biaya masak sendiri per porsi
        const costRicePerPortion = priceRice / 11; // 1kg beras = 11 porsi nasi
        const costSidePerPortion = priceSide / sidePortions;
        const totalHomeCostPerPortion = costRicePerPortion + costSidePerPortion + priceOverhead;

        // 2. Tampilkan Hasil Analisis ke User
        const resultBox = document.getElementById('result-box');
        if (!resultBox) return;

        let htmlResult = `
            <h4 class="font-bold text-base mb-3 text-center border-b pb-2 text-slate-700">📋 Rincian Analisis Finansial (Per Porsi)</h4>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4 text-xs">
                <div>
                    <span class="font-semibold text-amber-700">🏠 Estimasi Masak Sendiri:</span>
                    <ul class="list-disc list-inside mt-1 space-y-0.5 text-slate-600">
                        <li>Nasi Putih: Rp ${Math.round(costRicePerPortion).toLocaleString('id-ID')}</li>
                        <li>Lauk + Sayur: Rp ${Math.round(costSidePerPortion).toLocaleString('id-ID')}</li>
                        <li>Bumbu & Gas: Rp ${priceOverhead.toLocaleString('id-ID')}</li>
                        <li class="font-bold text-slate-800 mt-1 border-t pt-1">Total: Rp ${Math.round(totalHomeCostPerPortion).toLocaleString('id-ID')} / porsi</li>
                    </ul>
                </div>
                <div>
                    <span class="font-semibold text-blue-700">🥡 Opsi Beli di Luar:</span>
                    <ul class="list-disc list-inside mt-1 space-y-0.5 text-slate-600">
                        <li class="font-bold text-slate-800">Total: Rp ${priceOutside.toLocaleString('id-ID')} / porsi</li>
                    </ul>
                </div>
            </div>
        `;

        // 3. Menentukan Opsi Mana yang Lebih Hemat
        if (totalHomeCostPerPortion < priceOutside) {
            const selisih = priceOutside - totalHomeCostPerPortion;
            const hematSebulan = selisih * 3 * 30; // Asumsi makan 3x sehari selama 30 hari
            resultBox.className = "mt-6 p-5 rounded-xl text-sm border bg-emerald-50 border-emerald-200 text-emerald-800";
            htmlResult += `
                <div class="p-3 bg-white rounded-lg border border-emerald-100 text-center">
                    🟢 <strong>Masak Sendiri LEBIH HEMAT Rp ${Math.round(selisih).toLocaleString('id-ID')} per porsi!</strong><br>
                    <p class="text-xs text-slate-500 mt-1">Jika Anda konsisten masak opsi ini untuk makan 3x sehari, Anda menghemat <strong>Rp ${Math.round(hematSebulan).toLocaleString('id-ID')}</strong> dalam sebulan.</p>
                </div>
            `;
        } else if (totalHomeCostPerPortion > priceOutside) {
            const selisih = totalHomeCostPerPortion - priceOutside;
            const rugiSebulan = selisih * 3 * 30;
            resultBox.className = "mt-6 p-5 rounded-xl text-sm border bg-rose-50 border-rose-200 text-rose-800";
            htmlResult += `
                <div class="p-3 bg-white rounded-lg border border-rose-100 text-center">
                    🔴 <strong>Beli di Luar LEBIH HEMAT Rp ${Math.round(selisih).toLocaleString('id-ID')} per porsi!</strong><br>
                    <p class="text-xs text-slate-500 mt-1">Kasus ini sering terjadi jika kuantitas lauk yang dimasak terlalu sedikit atau bahan mentahnya terlalu mahal. Selisih pengeluaran Anda mencapai <strong>Rp ${Math.round(rugiSebulan).toLocaleString('id-ID')}</strong> per bulan jika memaksakan masak menu ini.</p>
                </div>
            `;
        } else {
            resultBox.className = "mt-6 p-5 rounded-xl text-sm border bg-slate-50 border-slate-200 text-slate-800";
            htmlResult += `<div class="p-3 bg-white rounded-lg border text-center">⚖️ Biayanya <strong>Sama Persis!</strong> Anda bebas memilih berdasarkan faktor tenaga atau waktu.</div>`;
        }

        resultBox.innerHTML = htmlResult;
        resultBox.classList.remove('hidden');
        resultBox.scrollIntoView({ behavior: 'smooth' });
    }

    // Ikat fungsi kalkulasi ke event listener tombol
    calcButton?.addEventListener('click', compareCookingCost);
</script>