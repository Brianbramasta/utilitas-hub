---
import { menuItems, type MenuItem } from '../lib/menuConfig';

interface Props {
    currentPath: string;
}

const { currentPath } = Astro.props;

// Fungsi helper untuk menghapus trailing slash agar perbandingan konsisten di prod & dev
const cleanPath = (path: string) => path.replace(/\/$/, "");
const normalizedCurrentPath = cleanPath(currentPath);
---

<button id="mobileMenuToggle" class="fixed top-4 left-4 z-50 md:hidden bg-green-700 text-white p-3 rounded-lg shadow-lg">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
</button>

<div id="sidebarOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

<aside id="sidebar" class="fixed md:sticky md:top-0 z-40 w-64 min-h-screen bg-white shadow-xl transform -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out">
    <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <a href="/" id="sidebarTitle" class="text-xl font-bold text-green-700 transition-opacity duration-300 cursor-pointer">Utilitas Hub</a>
           <button id="minimizeBtn" class="hidden md:flex items-center justify-center p-2 rounded-lg hover:bg-green-50 text-gray-600 hover:text-green-700 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" id="minimizeIcon" class="h-5 w-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
            </svg>
        </button>
    </div>
    <nav class="p-4">
        <ul class="space-y-2">
            {menuItems.map((item, index) => {
                const hasActiveChild = item.children?.some(child => child.href && cleanPath(child.href) === normalizedCurrentPath);
                const isParentActive = hasActiveChild;
                
                return (
                    <li>
                        {item.children ? (
                            <>
                                <button
                                    class={`menu-toggle w-full flex items-center justify-between p-3 rounded-lg transition-colors ${isParentActive ? 'bg-green-100 text-green-700' : 'text-gray-700 hover:bg-green-50 hover:text-green-700'}`}
                                    data-menu-index={index}
                                    data-expanded={isParentActive ? "true" : "false"}
                                >
                                    <div class="flex items-center">
                                        <Fragment set:html={item.icon} />
                                        <span class="sidebar-text ml-3 whitespace-nowrap transition-opacity duration-300">{item.name}</span>
                                    </div>
                                    <svg xmlns="http://www.w3.org/2000/svg" class={`menu-chevron h-4 w-4 flex-shrink-0 transition-transform duration-300 ${isParentActive ? 'rotate-180' : ''}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                <ul class={`menu-submenu ml-4 mt-1 space-y-1 ${isParentActive ? '' : 'hidden'}`}>
                                    {item.children.map((child) => {
                                        const isActive = child.href && cleanPath(child.href) === normalizedCurrentPath;
                                        return (
                                            <li data-requires-auth={child.requiresAuth ? 'true' : 'false'} data-href={child.href || ''}>
                                                <a href={child.href} data-auth-link="true" class={`flex items-center p-2 rounded-lg transition-colors ${isActive ? 'bg-green-100 text-green-700' : 'text-gray-600 hover:bg-green-50 hover:text-green-700'}`}>
                                                    <Fragment set:html={child.icon} />
                                                    <span class="sidebar-text ml-2 whitespace-nowrap text-sm transition-opacity duration-300">{child.name}</span>
                                                </a>
                                            </li>
                                        );
                                    })}
                                </ul>
                            </>
                        ) : (
                            <a href={item.href} class={`flex items-center p-3 rounded-lg transition-colors ${item.href && cleanPath(item.href) === normalizedCurrentPath ? 'bg-green-100 text-green-700' : 'text-gray-700 hover:bg-green-50 hover:text-green-700'}`}>
                                <Fragment set:html={item.icon} />
                                <span class="sidebar-text ml-3 whitespace-nowrap transition-opacity duration-300">{item.name}</span>
                            </a>
                        )}
                    </li>
                );
            })}
        </ul>
    </nav>
    
    <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-200 bg-white">
        <button
            id="authBtn"
            class="w-full flex items-center justify-center p-3 rounded-lg transition-colors bg-green-700 text-white hover:bg-green-800"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
            </svg>
            <span class="sidebar-text">Login</span>
        </button>
    </div>
</aside>

<script>
    const mobileMenuToggle = document.getElementById('mobileMenuToggle');
    const sidebar = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const minimizeBtn = document.getElementById('minimizeBtn');
    const minimizeIcon = document.getElementById('minimizeIcon');
    const sidebarTitle = document.getElementById('sidebarTitle');
    const sidebarTexts = document.querySelectorAll('.sidebar-text');
    const menuToggles = document.querySelectorAll('.menu-toggle');
    const authBtn = document.getElementById('authBtn');
    
    let isMinimized = false;

    function toggleSidebar() {
        sidebar?.classList.toggle('-translate-x-full');
        sidebarOverlay?.classList.toggle('hidden');
    }

    function toggleMinimize() {
        isMinimized = !isMinimized;
        
        if (sidebar) {
            sidebar.classList.toggle('w-64', !isMinimized);
            sidebar.classList.toggle('w-20', isMinimized);
        }
        
        if (sidebarTitle) {
            sidebarTitle.classList.toggle('opacity-0', isMinimized);
            sidebarTitle.classList.toggle('opacity-100', !isMinimized);
        }
        
        if (minimizeIcon) {
            minimizeIcon.style.transform = isMinimized ? 'rotate(180deg)' : 'rotate(0deg)';
        }
        
        sidebarTexts.forEach(text => {
            text.classList.toggle('opacity-0', isMinimized);
            text.classList.toggle('opacity-100', !isMinimized);
            text.classList.toggle('w-0', isMinimized);
        });
    }

    function toggleMenu(button: HTMLElement) {
        const submenu = button.nextElementSibling as HTMLElement;
        const chevron = button.querySelector('.menu-chevron') as HTMLElement;
        
        if (submenu && submenu.classList.contains('menu-submenu')) {
            const isHidden = submenu.classList.contains('hidden');
            submenu.classList.toggle('hidden');
            if (chevron) {
                chevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
            }
        }
    }

    // Check authentication and hide menu items that require auth
    function checkAuthAndHideMenuItems() {
        const isAuthenticated = localStorage.getItem('authenticated') === 'true';
        const authRequiredItems = document.querySelectorAll('[data-requires-auth="true"]');
        
        authRequiredItems.forEach((item) => {
            if (!isAuthenticated) {
                (item as HTMLElement).style.display = 'none';
            } else {
                (item as HTMLElement).style.display = '';
            }
        });

        // Update auth button
        updateAuthButton();
    }

    // Update auth button based on authentication status
    function updateAuthButton() {
        const isAuthenticated = localStorage.getItem('authenticated') === 'true';
        const btnText = authBtn?.querySelector('.sidebar-text');
        const btnIcon = authBtn?.querySelector('svg');
        
        if (isAuthenticated) {
            if (btnText) btnText.textContent = 'Logout';
            if (btnIcon) {
                btnIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />';
            }
            authBtn?.classList.remove('bg-green-700', 'hover:bg-green-800');
            authBtn?.classList.add('bg-red-600', 'hover:bg-red-700');
        } else {
            if (btnText) btnText.textContent = 'Login';
            if (btnIcon) {
                btnIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />';
            }
            authBtn?.classList.remove('bg-red-600', 'hover:bg-red-700');
            authBtn?.classList.add('bg-green-700', 'hover:bg-green-800');
        }
    }

    // Handle auth button click
    authBtn?.addEventListener('click', () => {
        const isAuthenticated = localStorage.getItem('authenticated') === 'true';
        
        if (isAuthenticated) {
            // Logout
            localStorage.removeItem('authenticated');
            localStorage.removeItem('userEmail');
            window.location.href = '/login';
        } else {
            // Go to login page
            window.location.href = '/login';
        }
    });

    // Handle auth-protected menu links
    document.querySelectorAll('[data-auth-link="true"]').forEach(link => {
        link.addEventListener('click', (e) => {
            const parentLi = link.closest('li');
            const requiresAuth = parentLi?.getAttribute('data-requires-auth') === 'true';
            
            if (requiresAuth) {
                const isAuthenticated = localStorage.getItem('authenticated') === 'true';
                if (!isAuthenticated) {
                    e.preventDefault();
                    window.location.href = '/login';
                }
            }
        });
    });

    mobileMenuToggle?.addEventListener('click', toggleSidebar);
    sidebarOverlay?.addEventListener('click', toggleSidebar);
    minimizeBtn?.addEventListener('click', toggleMinimize);
    
    menuToggles.forEach(toggle => {
        toggle.addEventListener('click', () => toggleMenu(toggle as HTMLElement));
    });

    // Run auth check on load
    checkAuthAndHideMenuItems();

    // Listen for storage changes (for logout in other tabs)
    window.addEventListener('storage', checkAuthAndHideMenuItems);
</script>
