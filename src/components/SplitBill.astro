---
// src/components/SplitBill.astro atau src/pages/index.astro
// Anda bisa memasukkan impor atau data statis di sini jika diperlukan di masa depan.
---

<div class="w-full max-w-xl bg-white p-6 rounded-xl shadow-md my-8 mx-auto font-sans text-gray-800">
  <h2 class="text-center mt-0 mb-6 text-indigo-600 text-2xl font-bold">Split Bill Calculator</h2>
  
  <!-- Input Biaya Tambahan Struk -->
  <div class="grid grid-cols-2 gap-3 mb-4">
    <div>
      <label class="block mb-1 font-semibold text-sm text-gray-700" for="tax">Total Pajak (Rp)</label>
      <input type="text" id="tax" value="0" class="w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none input-nominal" />
    </div>
    <div>
      <label class="block mb-1 font-semibold text-sm text-gray-700" for="tip">Total Tip / Service (Rp)</label>
      <input type="text" id="tip" value="0" class="w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none input-nominal" />
    </div>
  </div>
  <div class="mb-4">
    <label class="block mb-1 font-semibold text-sm text-gray-700" for="discount">Total Diskon Struk (Rp)</label>
    <input type="text" id="discount" value="0" class="w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none input-nominal" />
  </div>

  <hr class="border-0 border-t border-gray-200 my-5" />

  <!-- Bagian Pengisian Pesanan Anggota -->
  <h3 class="text-center mt-0 mb-4 text-indigo-600 text-xl font-semibold">Pesanan Anggota</h3>
  <div id="orders-container">
    <!-- Baris order default -->
    <div class="grid grid-cols-[1fr_1fr_auto] gap-3 mb-3 items-center order-row">
      <input type="text" placeholder="Nama Orang" class="member-name w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none" required />
      <input type="text" placeholder="Subtotal Menu (Rp)" class="member-subtotal w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none input-nominal" required />
      <button type="button" class="cursor-pointer rounded-md font-semibold border-none transition-colors duration-200 bg-red-500 hover:bg-red-600 text-white p-2.5 flex items-center justify-center min-w-[42px] btn-delete">✕</button>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-3 mt-4">
    <button type="button" id="btn-add-person" class="cursor-pointer rounded-md font-semibold border-none transition-colors duration-200 bg-emerald-500 hover:bg-emerald-600 text-white py-2.5 px-4 text-sm w-full">+ Tambah Orang</button>
    <button type="button" id="btn-calculate" class="cursor-pointer rounded-md font-semibold border-none transition-colors duration-200 bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 px-4 text-base w-full">Hitung Patungan</button>
  </div>

  <!-- Tempat Menampilkan Hasil Analisis Matematika -->
  <div class="mt-6 border-t-2 border-dashed border-gray-200 pt-5 hidden" id="result-box">
    <h3 class="text-center mt-0 mb-4 text-indigo-600 text-xl font-semibold">Hasil Pembagian Adil</h3>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse mt-4 text-sm text-left">
        <thead>
          <tr class="bg-gray-50 text-gray-700 border border-gray-200">
            <th class="border border-gray-200 p-2.5">Nama</th>
            <th class="border border-gray-200 p-2.5">Harga Menu</th>
            <th class="border border-gray-200 p-2.5">Pajak + Tip</th>
            <th class="border border-gray-200 p-2.5">Diskon</th>
            <th class="border border-gray-200 p-2.5">Total Bayar</th>
          </tr>
        </thead>
        <tbody id="result-body" class="text-gray-600">
          <!-- Data hasil kalkulasi dimasukkan lewat JS -->
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  // Fungsi untuk memformat angka menjadi format ribuan dengan titik
  function formatRupiah(angka: string): string {
    let numberString = angka.replace(/[^,\d]/g, '').toString();
    let split = numberString.split(',');
    let sisa = split[0].length % 3;
    let rupiah = split[0].slice(0, sisa);
    let ribuan = split[0].slice(sisa).match(/\d{3}/gi);

    if (ribuan) {
      let separator = sisa ? '.' : '';
      rupiah += separator + ribuan.join('.');
    }

    return split[1] !== undefined ? rupiah + ',' + split[1] : rupiah;
  }

  // Fungsi trigger format saat user mengetik
  function handleFormatInput(event: Event) {
    const element = event.target as HTMLInputElement;
    let cursorPosition = element.selectionStart || 0;
    let originalLength = element.value.length;
    
    element.value = formatRupiah(element.value);
    
    let newLength = element.value.length;
    element.setSelectionRange(cursorPosition + (newLength - originalLength), cursorPosition + (newLength - originalLength));
  }

  // Mengubah string ber-titik kembali menjadi angka murni
  function parseNominal(value: string): number {
    if (!value) return 0;
    return parseFloat(value.replace(/\./g, '')) || 0;
  }

  // Fungsi delegasi hapus baris
  function setupDeleteEvents() {
    const container = document.getElementById('orders-container');
    container?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target && target.classList.contains('btn-delete')) {
        const rows = document.querySelectorAll('.order-row');
        if (rows.length > 1) {
          target.parentElement?.remove();
        } else {
          alert('Minimal harus ada satu orang pembayar!');
        }
      }
    });
  }

  // Inisialisasi Event Listener dengan standar Astro (mendukung View Transitions jika aktif)
  function init() {
    const container = document.getElementById('orders-container');
    const btnAdd = document.getElementById('btn-add-person');
    const btnCalculate = document.getElementById('btn-calculate');

    // Event listener untuk format nominal otomatis (Event Delegation)
    document.addEventListener('input', (e) => {
      const target = e.target as HTMLElement;
      if (target && target.classList.contains('input-nominal')) {
        handleFormatInput(e);
      }
    });

    // Tambah Baris Baru
    btnAdd?.addEventListener('click', () => {
      if (!container) return;
      const row = document.createElement('div');
      row.className = 'grid grid-cols-[1fr_1fr_auto] gap-3 mb-3 items-center order-row';
      row.innerHTML = `
        <input type="text" placeholder="Nama Orang" class="member-name w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none" required />
        <input type="text" placeholder="Subtotal Menu (Rp)" class="member-subtotal w-full p-2.5 border border-gray-300 rounded-md text-base box-border focus:ring-2 focus:ring-indigo-500 focus:outline-none input-nominal" required />
        <button type="button" class="cursor-pointer rounded-md font-semibold border-none transition-colors duration-200 bg-red-500 hover:bg-red-600 text-white p-2.5 flex items-center justify-center min-w-[42px] btn-delete">✕</button>
      `;
      container.appendChild(row);
    });

    // Set up hapus baris
    setupDeleteEvents();

    // Kalkulasi Data
    btnCalculate?.addEventListener('click', () => {
      const taxInput = document.getElementById('tax') as HTMLInputElement;
      const tipInput = document.getElementById('tip') as HTMLInputElement;
      const discountInput = document.getElementById('discount') as HTMLInputElement;

      const totalTax = parseNominal(taxInput?.value || '0');
      const totalTip = parseNominal(tipInput?.value || '0');
      const totalDiscount = parseNominal(discountInput?.value || '0');

      const nameInputs = document.querySelectorAll('.member-name') as NodeListOf<HTMLInputElement>;
      const subtotalInputs = document.querySelectorAll('.member-subtotal') as NodeListOf<HTMLInputElement>;

      let grandSubtotal = 0;
      let orders = [];

      for (let i = 0; i < nameInputs.length; i++) {
        const name = nameInputs[i].value.trim() || `Orang ${i + 1}`;
        const subtotal = parseNominal(subtotalInputs[i].value);
        
        grandSubtotal += subtotal;
        orders.push({ name, subtotal });
      }

      if (grandSubtotal === 0) {
        alert('Masukkan harga pesanan terlebih dahulu!');
        return;
      }

      let htmlTableRows = '';
      let totalFinalBill = 0;

      orders.forEach(order => {
        const ratio = order.subtotal / grandSubtotal;
        const allocatedTaxTip = ratio * (totalTax + totalTip);
        const allocatedDiscount = ratio * totalDiscount;
        const totalToPay = order.subtotal + allocatedTaxTip - allocatedDiscount;

        totalFinalBill += totalToPay;

        htmlTableRows += `
          <tr class="border border-gray-200">
            <td class="border border-gray-200 p-2.5 text-gray-900 font-medium">${order.name}</td>
            <td class="border border-gray-200 p-2.5">Rp ${order.subtotal.toLocaleString('id-ID')}</td>
            <td class="border border-gray-200 p-2.5 text-red-500">+Rp ${Math.round(allocatedTaxTip).toLocaleString('id-ID')}</td>
            <td class="border border-gray-200 p-2.5 text-emerald-500">-Rp ${Math.round(allocatedDiscount).toLocaleString('id-ID')}</td>
            <td class="border border-gray-200 p-2.5 text-gray-900 font-bold">Rp ${Math.round(totalToPay).toLocaleString('id-ID')}</td>
          </tr>
        `;
      });

      htmlTableRows += `
        <tr class="font-bold bg-indigo-50 text-indigo-900 border border-gray-200">
          <td class="border border-gray-200 p-2.5">TOTAL</td>
          <td class="border border-gray-200 p-2.5">Rp ${grandSubtotal.toLocaleString('id-ID')}</td>
          <td class="border border-gray-200 p-2.5">Rp ${(totalTax + totalTip).toLocaleString('id-ID')}</td>
          <td class="border border-gray-200 p-2.5">Rp ${totalDiscount.toLocaleString('id-ID')}</td>
          <td class="border border-gray-200 p-2.5">Rp ${Math.round(totalFinalBill).toLocaleString('id-ID')}</td>
        </tr>
      `;

      const resultBody = document.getElementById('result-body');
      const resultBox = document.getElementById('result-box');
      
      if (resultBody && resultBox) {
        resultBody.innerHTML = htmlTableRows;
        resultBox.classList.remove('hidden');
        resultBox.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }

  // Jalankan inisialisasi script saat halaman dimuat
  init();
  // Jika proyek menggunakan Astro View Transitions, pastikan script berjalan ulang setelah navigasi halaman:
  document.addEventListener('astro:page-load', init);
</script>