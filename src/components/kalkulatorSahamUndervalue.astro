---
---

<div id="kalkulator-container" class="bg-white p-10 rounded-2xl shadow-xl w-full max-w-4xl mx-auto my-10">
    <h2 class="text-green-700 text-center mt-0 mb-8 border-b border-green-600 pb-4 text-2xl font-bold">Kalkulator Valuasi Saham Undervalue</h2>
    
    <!-- Action Buttons -->
    <div id="action-buttons" class="flex gap-4 mb-6 hidden">
      
        <button id="btnPrintPDF" class="flex-1 bg-purple-600 text-white border-none py-3 text-lg font-bold rounded-lg cursor-pointer hover:bg-purple-700 transition-colors flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            Print PDF
        </button>
    </div>
    
    <!-- Tabs -->
    <div class="flex border-b border-gray-200 mb-6">
        <button class="tab-btn active px-6 py-3 font-semibold text-green-700 border-b-2 border-green-700" data-tab="relative">
            Valuasi Relatif
        </button>
        <button class="tab-btn px-6 py-3 font-semibold text-gray-500 hover:text-green-700" data-tab="intrinsic">
            Nilai Intrinsik
        </button>
        <button class="tab-btn px-6 py-3 font-semibold text-gray-500 hover:text-green-700" data-tab="dividend">
            Pendekatan Dividen
        </button>
    </div>

    <!-- Tab Content: Valuasi Relatif -->
    <div id="tab-relative" class="tab-content">
        <div class="flex flex-col md:flex-row gap-6 mb-6">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="stockPrice" class="font-semibold text-base text-slate-700">Harga Saham Saat Ini (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Harga saham yang sedang diperdagangkan di bursa saat ini. Dapat diperoleh dari platform trading saham atau situs finansial seperti Yahoo Finance, Bloomberg, atau IDX.
                        </div>
                    </div>
                </div>
                <input type="text" id="stockPrice" value="5000" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="eps" class="font-semibold text-base text-slate-700">Earnings Per Share (EPS) (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Laba bersih perusahaan per lembar saham. Dihitung dari Laba Bersih dibagi Jumlah Saham Beredar. Diperoleh dari Laporan Keuangan tahunan atau kuartalan perusahaan.
                        </div>
                    </div>
                </div>
                <input type="text" id="eps" value="500" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-6 mb-6">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="bvps" class="font-semibold text-base text-slate-700">Book Value per Share (BVPS) (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Nilai buku per lembar saham. Dihitung dari Total Ekuitas dibagi Jumlah Saham Beredar. Diperoleh dari Laporan Posisi Keuangan (Neraca) perusahaan.
                        </div>
                    </div>
                </div>
                <input type="text" id="bvps" value="6000" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="epsGrowth" class="font-semibold text-base text-slate-700">Pertumbuhan EPS (%):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Persentase pertumbuhan EPS tahunan. Dapat dihitung dari data historis 3-5 tahun terakhir atau berdasarkan proyeksi analis. Diperoleh dari situs finansial atau laporan analis.
                        </div>
                    </div>
                </div>
                <input type="number" id="epsGrowth" value="10" step="0.1" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-6 mb-8">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="avgPerIndustry" class="font-semibold text-base text-slate-700">Rata-rata PER Industri:</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            PER rata-rata perusahaan sejenis dalam industri yang sama. Diperoleh dari situs finansial seperti Bloomberg, Reuters, atau IDX Statistics.
                        </div>
                    </div>
                </div>
                <input type="number" id="avgPerIndustry" value="15" step="0.1" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="avgPbvIndustry" class="font-semibold text-base text-slate-700">Rata-rata PBV Industri:</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            PBV rata-rata perusahaan sejenis dalam industri yang sama. Diperoleh dari sumber yang sama dengan rata-rata PER industri.
                        </div>
                    </div>
                </div>
                <input type="number" id="avgPbvIndustry" value="1.5" step="0.1" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
        </div>

        <button id="btnHitungRelative" class="w-full bg-green-700 text-white border-none py-4 text-xl font-bold rounded-lg cursor-pointer hover:bg-green-800 transition-colors">Hitung Valuasi Relatif</button>

        <div class="mt-8 p-6 bg-green-50 border-l-4 border-green-700 rounded hidden" id="resultBoxRelative">
            <h3 class="mt-0 mb-6 text-green-700 text-xl font-bold">Hasil Valuasi Relatif:</h3>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Price to Earnings Ratio (PER):</span>
                <span class="font-bold text-xl" id="resPer">0</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Kategori PER:</span>
                <span class="font-bold text-xl" id="resPerCategory">-</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Price to Book Value (PBV):</span>
                <span class="font-bold text-xl" id="resPbv">0</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Kategori PBV:</span>
                <span class="font-bold text-xl" id="resPbvCategory">-</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Price to Earnings Growth (PEG):</span>
                <span class="font-bold text-xl" id="resPeg">0</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg">
                <span class="text-slate-700">Kategori PEG:</span>
                <span class="font-bold text-xl" id="resPegCategory">-</span>
            </div>
            
            <div class="mt-6 p-4 rounded-lg text-center font-bold text-lg" id="resConclusionRelative">
                -
            </div>
        </div>
    </div>

    <!-- Tab Content: Nilai Intrinsik -->
    <div id="tab-intrinsic" class="tab-content hidden">
        <div class="flex flex-col md:flex-row gap-6 mb-6">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="stockPriceIntrinsic" class="font-semibold text-base text-slate-700">Harga Saham Saat Ini (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Harga saham yang sedang diperdagangkan di bursa saat ini.
                        </div>
                    </div>
                </div>
                <input type="text" id="stockPriceIntrinsic" value="5000" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="epsIntrinsic" class="font-semibold text-base text-slate-700">Earnings Per Share (EPS) (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Laba bersih perusahaan per lembar saham dari laporan keuangan.
                        </div>
                    </div>
                </div>
                <input type="text" id="epsIntrinsic" value="500" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
        </div>

        <div class="flex flex-col mb-6">
            <div class="flex items-center gap-2 mb-2">
                <label for="bvpsIntrinsic" class="font-semibold text-base text-slate-700">Book Value per Share (BVPS) (Rp):</label>
                <div class="relative group">
                    <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                    </svg>
                    <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                        Nilai buku per lembar saham dari laporan posisi keuangan.
                    </div>
                </div>
            </div>
            <input type="text" id="bvpsIntrinsic" value="6000" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
        </div>

        <div class="flex flex-col md:flex-row gap-6 mb-6">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="fcf" class="font-semibold text-base text-slate-700">Free Cash Flow Tahunan (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Kas bersih yang dihasilkan perusahaan setelah dikurangi biaya operasional dan belanja modal. Diperoleh dari Laporan Arus Kas perusahaan.
                        </div>
                    </div>
                </div>
                <input type="text" id="fcf" value="100000000000" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="sharesOutstanding" class="font-semibold text-base text-slate-700">Jumlah Saham Beredar:</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Total jumlah saham yang beredar dan dimiliki oleh investor. Diperoleh dari Laporan Keuangan atau situs IDX.
                        </div>
                    </div>
                </div>
                <input type="text" id="sharesOutstanding" value="10000000000" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-6 mb-6">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="growthRate" class="font-semibold text-base text-slate-700">Tingkat Pertumbuhan FCF (%):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Proyeksi pertumbuhan Free Cash Flow tahunan. Biasanya menggunakan rata-rata historis atau proyeksi analis, umumnya 3-7%.
                        </div>
                    </div>
                </div>
                <input type="number" id="growthRate" value="5" step="0.1" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="discountRate" class="font-semibold text-base text-slate-700">Tingkat Diskonto (%):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                            Tingkat pengembalian yang diinginkan investor (WACC). Biasanya 8-15% tergantung risiko perusahaan dan industri.
                        </div>
                    </div>
                </div>
                <input type="number" id="discountRate" value="10" step="0.1" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
            </div>
        </div>

        <div class="flex flex-col mb-8">
            <div class="flex items-center gap-2 mb-2">
                <label for="marginOfSafety" class="font-semibold text-base text-slate-700">Margin of Safety (%):</label>
                <div class="relative group">
                    <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                    </svg>
                    <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-64 p-3 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                        Buffer keamanan untuk melindungi dari kesalahan proyeksi. Warren Buffett biasanya menggunakan 20-30%.
                    </div>
                </div>
            </div>
            <input type="number" id="marginOfSafety" value="20" step="1" min="0" max="100" class="w-full p-3 border border-slate-300 rounded-lg text-lg">
        </div>

        <div class="flex gap-4 mb-8">
            <button id="btnHitungGraham" class="flex-1 bg-green-700 text-white border-none py-4 text-lg font-bold rounded-lg cursor-pointer hover:bg-green-800 transition-colors">Hitung Rumus Graham</button>
            <button id="btnHitungDCF" class="flex-1 bg-green-700 text-white border-none py-4 text-lg font-bold rounded-lg cursor-pointer hover:bg-green-800 transition-colors">Hitung DCF</button>
        </div>

        <div class="mt-8 p-6 bg-green-50 border-l-4 border-green-700 rounded hidden" id="resultBoxIntrinsic">
            <h3 class="mt-0 mb-6 text-green-700 text-xl font-bold">Hasil Nilai Intrinsik:</h3>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Metode:</span>
                <span class="font-bold text-xl" id="resMethod">-</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Nilai Intrinsik:</span>
                <span class="font-bold text-xl" id="resIntrinsicValue">Rp 0</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg border-b border-dashed border-green-300">
                <span class="text-slate-700">Harga Aman (MoS):</span>
                <span class="font-bold text-xl" id="resSafePrice">Rp 0</span>
            </div>
            
            <div class="flex justify-between items-center py-3 text-lg">
                <span class="text-slate-700">Potensi Kenaikan:</span>
                <span class="font-bold text-xl" id="resUpside">0%</span>
            </div>
            
            <div class="mt-6 p-4 rounded-lg text-center font-bold text-lg" id="resConclusionIntrinsic">
                -
            </div>
        </div>
    </div>

    <!-- Tab Content: Pendekatan Dividen -->
    <div id="tab-dividend" class="tab-content hidden">
        <div class="flex flex-col md:flex-row gap-6 mb-6">
            <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2">
                    <label for="stockPriceDividend" class="font-semibold text-base text-slate-700">Harga Saham Saat Ini (Rp):</label>
                    <div class="relative group">
                        <svg class="w-5 h-5 text-gray-400 hover:text-gray-600 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 6h.01"></path>
                        </svg>
