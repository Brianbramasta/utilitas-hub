<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script>
    function formatRupiah(angka: number): string {
        return "Rp " + Math.round(angka).toLocaleString('id-ID', { useGrouping: true, maximumFractionDigits: 0 });
    }

    function formatInputRupiah(input: HTMLInputElement): void {
        let value = input.value.replace(/[^0-9]/g, '');
        if (value) {
            const num = parseInt(value);
            input.value = num.toLocaleString('id-ID', { useGrouping: true, maximumFractionDigits: 0 });
        }
    }

    function unformatRupiah(value: string): number {
        return parseInt(value.replace(/[^0-9]/g, '')) || 0;
    }

    function setCategory(element: HTMLElement, isUndervalue: boolean, text: string) {
        element.textContent = text;
        element.className = `font-bold text-xl ${isUndervalue ? 'text-green-700' : 'text-red-600'}`;
    }

    function setConclusion(element: HTMLElement, isUndervalue: boolean, text: string) {
        element.textContent = text;
        element.className = `mt-6 p-4 rounded-lg text-center font-bold text-lg ${isUndervalue ? 'bg-green-200 text-green-800' : 'bg-red-200 text-red-800'}`;
    }

    // Tab switching
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const tabId = btn.getAttribute('data-tab');
            
            // Remove active class from all buttons
            tabBtns.forEach(b => {
                b.classList.remove('active', 'text-green-700', 'border-green-700');
                b.classList.add('text-gray-500');
            });
            
            // Hide all contents
            tabContents.forEach(content => content.classList.add('hidden'));
            
            // Activate current tab
            btn.classList.add('active', 'text-green-700', 'border-green-700');
            btn.classList.remove('text-gray-500');
            document.getElementById(`tab-${tabId}`)?.classList.remove('hidden');
        });
    });

    // VALUASI RELATIF
    function hitungValuasiRelatif() {
        const stockPriceEl = document.getElementById('stockPrice') as HTMLInputElement | null;
        const epsEl = document.getElementById('eps') as HTMLInputElement | null;
        const bvpsEl = document.getElementById('bvps') as HTMLInputElement | null;
        const epsGrowthEl = document.getElementById('epsGrowth') as HTMLInputElement | null;
        const avgPerIndustryEl = document.getElementById('avgPerIndustry') as HTMLInputElement | null;
        const avgPbvIndustryEl = document.getElementById('avgPbvIndustry') as HTMLInputElement | null;
        
        const resPerEl = document.getElementById('resPer') as HTMLElement | null;
        const resPerCategoryEl = document.getElementById('resPerCategory') as HTMLElement | null;
        const resPbvEl = document.getElementById('resPbv') as HTMLElement | null;
        const resPbvCategoryEl = document.getElementById('resPbvCategory') as HTMLElement | null;
        const resPegEl = document.getElementById('resPeg') as HTMLElement | null;
        const resPegCategoryEl = document.getElementById('resPegCategory') as HTMLElement | null;
        const resConclusionRelativeEl = document.getElementById('resConclusionRelative') as HTMLElement | null;
        const resultBoxRelativeEl = document.getElementById('resultBoxRelative') as HTMLElement | null;

        if (!stockPriceEl || !epsEl || !bvpsEl || !epsGrowthEl || !avgPerIndustryEl || !avgPbvIndustryEl ||
            !resPerEl || !resPerCategoryEl || !resPbvEl || !resPbvCategoryEl || !resPegEl || !resPegCategoryEl ||
            !resConclusionRelativeEl || !resultBoxRelativeEl) {
            return;
        }

        const stockPrice = unformatRupiah(stockPriceEl.value);
        const eps = unformatRupiah(epsEl.value);
        const bvps = unformatRupiah(bvpsEl.value);
        const epsGrowth = parseFloat(epsGrowthEl.value) / 100;
        const avgPerIndustry = parseFloat(avgPerIndustryEl.value);
        const avgPbvIndustry = parseFloat(avgPbvIndustryEl.value);

        // PER Calculation
        const per = stockPrice / eps;
        const isPerUndervalue = per < avgPerIndustry;
        
        // PBV Calculation
        const pbv = stockPrice / bvps;
        const isPbvUndervalue = pbv < 1 || pbv < avgPbvIndustry;
        
        // PEG Calculation
        const peg = per / (epsGrowth * 100);
        const isPegUndervalue = peg < 1;

        // Display results
        resPerEl.textContent = per.toFixed(2);
        setCategory(resPerCategoryEl, isPerUndervalue, isPerUndervalue ? 'Undervalue' : 'Overvalue');
        
        resPbvEl.textContent = pbv.toFixed(2);
        setCategory(resPbvCategoryEl, isPbvUndervalue, isPbvUndervalue ? 'Undervalue' : 'Overvalue');
        
        resPegEl.textContent = peg.toFixed(2);
        setCategory(resPegCategoryEl, isPegUndervalue, isPegUndervalue ? 'Undervalue' : 'Overvalue');

        // Overall conclusion
        const undervalueCount = [isPerUndervalue, isPbvUndervalue, isPegUndervalue].filter(Boolean).length;
        const isOverallUndervalue = undervalueCount >= 2;
        const conclusionText = isOverallUndervalue 
            ? `✅ Saham ini cenderung UNDERVALUE (${undervalueCount}/3 indikator)`
            : `⚠️ Saham ini cenderung OVERVALUE (${undervalueCount}/3 indikator)`;
        
        setConclusion(resConclusionRelativeEl, isOverallUndervalue, conclusionText);
        
        resultBoxRelativeEl.classList.remove('hidden');
    }

    // NILAI INTRINSIK - GRAHAM
    function hitungGraham() {
        const stockPriceEl = document.getElementById('stockPriceIntrinsic') as HTMLInputElement | null;
        const epsEl = document.getElementById('epsIntrinsic') as HTMLInputElement | null;
        const bvpsEl = document.getElementById('bvpsIntrinsic') as HTMLInputElement | null;
        const marginOfSafetyEl = document.getElementById('marginOfSafety') as HTMLInputElement | null;
        
        const resMethodEl = document.getElementById('resMethod') as HTMLElement | null;
        const resIntrinsicValueEl = document.getElementById('resIntrinsicValue') as HTMLElement | null;
        const resSafePriceEl = document.getElementById('resSafePrice') as HTMLElement | null;
        const resUpsideEl = document.getElementById('resUpside') as HTMLElement | null;
        const resConclusionIntrinsicEl = document.getElementById('resConclusionIntrinsic') as HTMLElement | null;
        const resultBoxIntrinsicEl = document.getElementById('resultBoxIntrinsic') as HTMLElement | null;

        if (!stockPriceEl || !epsEl || !bvpsEl || !marginOfSafetyEl ||
            !resMethodEl || !resIntrinsicValueEl || !resSafePriceEl || !resUpsideEl ||
            !resConclusionIntrinsicEl || !resultBoxIntrinsicEl) {
            return;
        }

        const stockPrice = unformatRupiah(stockPriceEl.value);
        const eps = unformatRupiah(epsEl.value);
        const bvps = unformatRupiah(bvpsEl.value);
        const marginOfSafety = parseFloat(marginOfSafetyEl.value) / 100;

        // Benjamin Graham Formula
        const intrinsicValue = Math.sqrt(22.5 * eps * bvps);
        const safePrice = intrinsicValue * (1 - marginOfSafety);
        const upside = ((intrinsicValue - stockPrice) / stockPrice) * 100;
        const isUndervalue = stockPrice < safePrice;

        resMethodEl.textContent = 'Benjamin Graham Formula';
        resIntrinsicValueEl.textContent = formatRupiah(intrinsicValue);
        resSafePriceEl.textContent = formatRupiah(safePrice);
        resUpsideEl.textContent = `${upside.toFixed(2)}%`;
        
        const conclusionText = isUndervalue
            ? '✅ Saham ini UNDERVALUE dan layak dibeli dengan MoS'
            : '⚠️ Saham ini OVERVALUE berdasarkan Rumus Graham';
        
        setConclusion(resConclusionIntrinsicEl, isUndervalue, conclusionText);
        
        resultBoxIntrinsicEl.classList.remove('hidden');
    }

    // NILAI INTRINSIK - DCF
    function hitungDCF() {
        const stockPriceEl = document.getElementById('stockPriceIntrinsic') as HTMLInputElement | null;
        const fcfEl = document.getElementById('fcf') as HTMLInputElement | null;
        const sharesOutstandingEl = document.getElementById('sharesOutstanding') as HTMLInputElement | null;
        const growthRateEl = document.getElementById('growthRate') as HTMLInputElement | null;
        const discountRateEl = document.getElementById('discountRate') as HTMLInputElement | null;
        const marginOfSafetyEl = document.getElementById('marginOfSafety') as HTMLInputElement | null;
        
        const resMethodEl = document.getElementById('resMethod') as HTMLElement | null;
        const resIntrinsicValueEl = document.getElementById('resIntrinsicValue') as HTMLElement | null;
        const resSafePriceEl = document.getElementById('resSafePrice') as HTMLElement | null;
        const resUpsideEl = document.getElementById('resUpside') as HTMLElement | null;
        const resConclusionIntrinsicEl = document.getElementById('resConclusionIntrinsic') as HTMLElement | null;
        const resultBoxIntrinsicEl = document.getElementById('resultBoxIntrinsic') as HTMLElement | null;

        if (!stockPriceEl || !fcfEl || !sharesOutstandingEl || !growthRateEl || !discountRateEl || !marginOfSafetyEl ||
            !resMethodEl || !resIntrinsicValueEl || !resSafePriceEl || !resUpsideEl ||
            !resConclusionIntrinsicEl || !resultBoxIntrinsicEl) {
            return;
        }

        const stockPrice = unformatRupiah(stockPriceEl.value);
        const fcf = unformatRupiah(fcfEl.value);
        const sharesOutstanding = unformatRupiah(sharesOutstandingEl.value);
        const growthRate = parseFloat(growthRateEl.value) / 100;
        const discountRate = parseFloat(discountRateEl.value) / 100;
        const marginOfSafety = parseFloat(marginOfSafetyEl.value) / 100;

        // Simplified DCF (Gordon Growth Model)
        if (discountRate <= growthRate) {
            alert('Tingkat diskonto harus lebih tinggi dari tingkat pertumbuhan!');
            return;
        }
        
        const terminalValue = fcf * (1 + growthRate) / (discountRate - growthRate);
        const presentValue = terminalValue; // Simplified
        const intrinsicValuePerShare = presentValue / sharesOutstanding;
        const safePrice = intrinsicValuePerShare * (1 - marginOfSafety);
        const upside = ((intrinsicValuePerShare - stockPrice) / stockPrice) * 100;
        const isUndervalue = stockPrice < safePrice;

        resMethodEl.textContent = 'Discounted Cash Flow (DCF)';
        resIntrinsicValueEl.textContent = formatRupiah(intrinsicValuePerShare);
        resSafePriceEl.textContent = formatRupiah(safePrice);
        resUpsideEl.textContent = `${upside.toFixed(2)}%`;
        
        const conclusionText = isUndervalue
            ? '✅ Saham ini UNDERVALUE dan layak dibeli dengan MoS'
            : '⚠️ Saham ini OVERVALUE berdasarkan DCF';
        
        setConclusion(resConclusionIntrinsicEl, isUndervalue, conclusionText);
        
        resultBoxIntrinsicEl.classList.remove('hidden');
    }

    // DIVIDEND DISCOUNT MODEL
    function hitungDDM() {
        const stockPriceEl = document.getElementById('stockPriceDividend') as HTMLInputElement | null;
        const dividendPerShareEl = document.getElementById('dividendPerShare') as HTMLInputElement | null;
        const dividendGrowthEl = document.getElementById('dividendGrowth') as HTMLInputElement | null;
        const requiredReturnEl = document.getElementById('requiredReturn') as HTMLInputElement | null;
        const marginOfSafetyEl = document.getElementById('marginOfSafetyDividend') as HTMLInputElement | null;
        
        const resDDMValueEl = document.getElementById('resDDMValue') as HTMLElement | null;
        const resSafePriceDividendEl = document.getElementById('resSafePriceDividend') as HTMLElement | null;
        const resDividendYieldEl = document.getElementById('resDividendYield') as HTMLElement | null;
        const resUpsideDividendEl = document.getElementById('resUpsideDividend') as HTMLElement | null;
        const resConclusionDividendEl = document.getElementById('resConclusionDividend') as HTMLElement | null;
        const resultBoxDividendEl = document.getElementById('resultBoxDividend') as HTMLElement | null;

        if (!stockPriceEl || !dividendPerShareEl || !dividendGrowthEl || !requiredReturnEl || !marginOfSafetyEl ||
            !resDDMValueEl || !resSafePriceDividendEl || !resDividendYieldEl || !resUpsideDividendEl ||
            !resConclusionDividendEl || !resultBoxDividendEl) {
            return;
        }

        const stockPrice = unformatRupiah(stockPriceEl.value);
        const dividendPerShare = unformatRupiah(dividendPerShareEl.value);
        const dividendGrowth = parseFloat(dividendGrowthEl.value) / 100;
        const requiredReturn = parseFloat(requiredReturnEl.value) / 100;
        const marginOfSafety = parseFloat(marginOfSafetyEl.value) / 100;

        if (requiredReturn <= dividendGrowth) {
            alert('Tingkat pengembalian yang diinginkan harus lebih tinggi dari pertumbuhan dividen!');
            return;
        }

        // Gordon Growth Model for DDM
        const ddmValue = dividendPerShare * (1 + dividendGrowth) / (requiredReturn - dividendGrowth);
        const safePrice = ddmValue * (1 - marginOfSafety);
        const dividendYield = (dividendPerShare / stockPrice) * 100;
        const upside = ((ddmValue - stockPrice) / stockPrice) * 100;
        const isUndervalue = stockPrice < safePrice;

        resDDMValueEl.textContent = formatRupiah(ddmValue);
        resSafePriceDividendEl.textContent = formatRupiah(safePrice);
        resDividendYieldEl.textContent = `${dividendYield.toFixed(2)}%`;
        resUpsideDividendEl.textContent = `${upside.toFixed(2)}%`;
        
        const conclusionText = isUndervalue
            ? '✅ Saham ini UNDERVALUE dan layak dibeli dengan MoS'
            : '⚠️ Saham ini OVERVALUE berdasarkan DDM';
        
        setConclusion(resConclusionDividendEl, isUndervalue, conclusionText);
        
        resultBoxDividendEl.classList.remove('hidden');
    }

    // Initialize rupiah formatting
    const rupiahInputs = [
        'stockPrice', 'eps', 'bvps',
        'stockPriceIntrinsic', 'epsIntrinsic', 'bvpsIntrinsic', 'fcf', 'sharesOutstanding',
        'stockPriceDividend', 'dividendPerShare'
    ];

    rupiahInputs.forEach(id => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el) {
            formatInputRupiah(el);
            el.addEventListener('input', () => formatInputRupiah(el));
        }
    });

    // Button event listeners
    document.getElementById('btnHitungRelative')?.addEventListener('click', hitungValuasiRelatif);
    document.getElementById('btnHitungGraham')?.addEventListener('click', hitungGraham);
    document.getElementById('btnHitungDCF')?.addEventListener('click', hitungDCF);
    document.getElementById('btnHitungDDM')?.addEventListener('click', hitungDDM);

