---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
    title?: string;
    no_sidebar?: boolean;
}

const { title = "Utilitas Hub", no_sidebar = false } = Astro.props;
const urlParams = new URLSearchParams(Astro.url.search);
const noSidebarFromUrl = urlParams.get('no_sidebar') === 'true';
const shouldShowSidebar = !no_sidebar && !noSidebarFromUrl;

// --- PERBAIKAN DI SINI: Ambil pathname saat ini ---
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    </head>
    <body class="m-0 w-full min-h-screen bg-green-50 font-sans">
        <div class="flex min-h-screen">
            {shouldShowSidebar && (
                <Sidebar currentPath={currentPath} />
            )}

            <main class="flex-1">
                <slot />
            </main>
        </div>

    </body>
</html>