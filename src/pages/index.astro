---
import Layout from '../layouts/Layout.astro';
import { menuItems } from '../lib/menuConfig';
---

<Layout title="Utilitas Hub">
	<div class="p-5 md:p-10 flex items-center justify-center min-h-screen">
		<div class="bg-white p-10 rounded-2xl shadow-xl w-full max-w-4xl text-center">
			<h1 class="text-green-700 text-3xl font-bold mb-4">Selamat Datang di Utilitas Hub</h1>
			<p class="text-slate-600 text-lg mb-6">Kumpulan alat bantu dan kalkulator keuangan</p>
			
			{menuItems.map((item) => (
				<div class="mb-8">
					<h2 class="text-green-700 text-xl font-bold mb-4">{item.name}</h2>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						{item.children?.filter(child => !child.requiresAuth).map((child) => (
							<a 
								href={child.href} 
								class="border-2 border-green-700 text-green-700 px-6 py-3 rounded-lg font-semibold hover:bg-green-50 transition-colors"
							>
								{child.name}
							</a>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</Layout>
